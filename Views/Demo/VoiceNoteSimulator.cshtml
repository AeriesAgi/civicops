@{
    ViewData["Title"] = "Voice-note Transcript Sandbox";
}
<div class="container py-4 civic-page">
    <section class="hero-panel mb-4">
        <span class="eyebrow">Accessibility intake scenario</span>
        <h1 class="display-5">Voice-note Transcript Sandbox</h1>
        <p class="lead">Submit a transcript as if it came from a voice note. CivicOps analyzes it only on submit and creates a routed incident with fallback available.</p>
    </section>
    <div class="row g-4">
        <div class="col-lg-5"><form id="voiceForm" class="ops-card"><h2 class="h4">Transcript</h2><label class="form-label">Area</label><input name="suburb" class="form-control mb-3" value="Umlazi" /><label class="form-label">Ward</label><input name="ward" class="form-control mb-3" value="Ward 80" /><label class="form-label">Duration seconds</label><input name="durationSeconds" class="form-control mb-3" value="34" /><label class="form-label">Transcript</label><textarea name="transcript" rows="7" class="form-control mb-3">There is a fallen electricity cable sparking near the community hall after the rain. People are walking close to it and the street lights are out.</textarea><button class="btn btn-primary btn-lg" type="submit">Analyze voice-note transcript</button></form></div>
        <div class="col-lg-7"><div class="ops-card"><h2 class="h4">Result</h2><div id="voiceResult" class="alert alert-info">Submit the transcript to create a civic incident.</div></div></div>
    </div>
</div>
<script>
(() => {
 const form=document.getElementById('voiceForm'), result=document.getElementById('voiceResult');
 form.addEventListener('submit', async e => { e.preventDefault(); result.className='alert alert-warning'; result.textContent='Analyzing transcript...'; const data=Object.fromEntries(new FormData(form).entries()); data.durationSeconds=parseInt(data.durationSeconds||'0',10); try { const res=await fetch('/demo/voicenote/submit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)}); const json=await res.json(); if(!res.ok) throw new Error(json.message||'Voice note failed'); result.className='alert alert-success'; result.innerHTML=`<strong>Reference:</strong> ${json.referenceNumber}<br><strong>Department:</strong> ${json.department}<br><strong>Category:</strong> ${json.category}<br><strong>Priority:</strong> ${json.priority}<br><strong>Citizen response:</strong> ${json.citizenResponse}<br><strong>Alert recommendation:</strong> ${json.alertRecommendation}`; } catch(err){ result.className='alert alert-danger'; result.textContent=err.message; }});
})();
</script>
