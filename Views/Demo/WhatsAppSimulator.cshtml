@{
    ViewData["Title"] = "WhatsApp Intake Sandbox / Connector Readiness";
}
<div class="container py-4 civic-page">
    <section class="hero-panel mb-4">
        <span class="eyebrow">Optional connector</span>
        <h1 class="display-5">WhatsApp Intake Sandbox / Connector Readiness</h1>
        <p class="lead">WhatsApp Cloud API is connector-ready for sandbox/live-test and future production pilots. Production use requires WhatsApp Business setup, opt-in/templates, and billing.</p>
        <div class="alert alert-info mb-0">CivicOps does not depend on WhatsApp; residents can report through Web/PWA/mobile immediately.</div>
    </section>
    <div class="row g-4">
        <div class="col-lg-5">
            <form id="waForm" class="ops-card">
                <h2 class="h4">Sandbox inbound message</h2>
                <label class="form-label">Sender name</label><input name="senderName" class="form-control mb-3" value="Sandbox Resident" />
                <label class="form-label">Masked phone</label><input name="phoneNumber" class="form-control mb-3" value="+27 82 *** 4567" />
                <label class="form-label">Area</label><input name="suburb" class="form-control mb-3" value="Chatsworth" />
                <label class="form-label">Ward</label><input name="ward" class="form-control mb-3" value="Ward 68" />
                <label class="form-label">Message</label><textarea name="message" rows="6" class="form-control mb-3">There is a burst water pipe flooding the road near the clinic entrance. The water is running into homes and children are walking through it.</textarea>
                <button class="btn btn-primary btn-lg" type="submit">Send sandbox report</button>
            </form>
        </div>
        <div class="col-lg-7"><div class="ops-card"><h2 class="h4">Result</h2><div id="waResult" class="alert alert-info">Submit the sandbox message to create a CivicOps incident via the shared IncidentIntakeService.</div></div></div>
    </div>
</div>
<script>
(() => {
  const form = document.getElementById('waForm');
  const result = document.getElementById('waResult');
  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    result.className='alert alert-warning'; result.textContent='Processing one sandbox inbound report...';
    const data = Object.fromEntries(new FormData(form).entries());
    try {
      const response = await fetch('/demo/whatsapp/inbound', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data)});
      const json = await response.json();
      if (!response.ok) throw new Error(json.message || 'Sandbox request failed');
      result.className='alert alert-success';
      result.innerHTML = `<strong>Reference:</strong> ${json.referenceNumber}<br><strong>Department:</strong> ${json.department}<br><strong>Priority:</strong> ${json.priority}<br><strong>Source:</strong> ${json.aiSource || 'Local deterministic fallback'}<br>${json.citizenResponse || ''}`;
    } catch (error) { result.className='alert alert-danger'; result.textContent=error.message; }
  });
})();
</script>
