@{
    ViewData["Title"] = "Resident Signup";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Resident profile</span><h1 class="display-5">Create a resident profile</h1><p class="lead">Follow areas, view your reports and optionally capture WhatsApp consent. WhatsApp is not required for registration.</p></section>
  @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
  <form method="post" class="ops-card"><div class="row g-3"><div class="col-md-6"><label class="form-label">Full name</label><input name="fullName" class="form-control" required /></div><div class="col-md-6"><label class="form-label">Email</label><input name="email" type="email" class="form-control" required /></div><div class="col-md-6"><label class="form-label">Password</label><input name="password" type="password" class="form-control" required /></div><div class="col-md-6"><label class="form-label">Contact</label><input name="phoneNumber" class="form-control" /></div><div class="col-md-6"><label class="form-label">Area / suburb</label><input name="areaSuburb" class="form-control" /></div><div class="col-md-6"><label class="form-label">Followed ward</label><input name="followedWard" class="form-control" placeholder="Ward 68" /></div><div class="col-md-6"><label class="form-label">WhatsApp number (optional)</label><input name="whatsappNumber" class="form-control" /></div><div class="col-12"><div class="form-check"><input name="whatsappConsent" value="true" class="form-check-input" type="checkbox" /><label class="form-check-label">I consent to optional WhatsApp sandbox/live-test messaging when configured.</label></div><p class="small text-muted-strong mt-2">In sandbox mode, WhatsApp recipients must be approved as test recipients. In production, opted-in residents can receive approved templates and service replies through WhatsApp Business setup.</p></div></div><button class="btn btn-primary btn-lg mt-4" type="submit">Create profile</button></form>
</div>
