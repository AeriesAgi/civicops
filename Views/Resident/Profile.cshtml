@model CivicOps.Models.ResidentUser
@{
    ViewData["Title"] = "Resident Profile";
    var statuses = new[] { "Not Linked", "Consent Captured", "Pending Sandbox Approval", "Sandbox Test Approved", "Live Messaging Ready", "Disabled" };
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Citizen preferences</span><h1 class="display-5">Resident profile</h1><p class="lead">Manage contact details, followed areas and optional WhatsApp consent. WhatsApp is never required to use CivicOps.</p></section>
  @if (ViewBag.Success != null) { <div class="alert alert-success">@ViewBag.Success</div> }
  <form method="post" action="/Resident/UpdateProfile" class="ops-card mb-4"><div class="row g-3"><div class="col-md-6"><label class="form-label">Full name</label><input name="fullName" value="@Model.FullName" class="form-control" /></div><div class="col-md-6"><label class="form-label">Email</label><input value="@Model.Email" class="form-control" disabled /></div><div class="col-md-6"><label class="form-label">Contact</label><input name="phoneNumber" value="@Model.PhoneNumber" class="form-control" /></div><div class="col-md-6"><label class="form-label">Area / suburb</label><input name="areaSuburb" value="@Model.AreaSuburb" class="form-control" /></div><div class="col-md-6"><label class="form-label">Followed area/ward</label><input name="primaryWard" value="@Model.PrimaryWard" class="form-control" /></div><div class="col-md-6"><label class="form-label">WhatsApp number (optional)</label><input name="whatsappNumber" value="@Model.WhatsAppNumber" class="form-control" /></div><div class="col-md-6"><label class="form-label">WhatsApp status</label><select name="whatsappStatus" class="form-select">@foreach (var status in statuses) { <option selected="@(Model.WhatsAppStatus == status)">@status</option> }</select></div><div class="col-md-6"><label class="form-label">Notifications</label><div class="form-check"><input class="form-check-input" type="checkbox" name="emailNotifications" value="true" checked="@Model.EmailNotifications" /><label class="form-check-label">Email notifications</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="smsNotifications" value="true" checked="@Model.SMSNotifications" /><label class="form-check-label">SMS notifications</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="alertNotifications" value="true" checked="@Model.AlertNotifications" /><label class="form-check-label">Area alerts</label></div></div><div class="col-12"><div class="form-check"><input class="form-check-input" type="checkbox" name="whatsappConsent" value="true" checked="@Model.WhatsAppConsent" /><label class="form-check-label">WhatsApp consent captured</label></div><p class="small text-muted-strong mt-2">In sandbox mode, WhatsApp recipients must be approved as test recipients. In production, opted-in residents can receive approved templates and service replies through WhatsApp Business setup.</p></div></div><button class="btn btn-primary mt-4" type="submit">Save profile</button></form>
  <div class="grid-auto"><div class="ops-card"><h2 class="h5">Followed suburbs</h2><p>@string.Join(", ", Model.FollowedSuburbs)</p></div><div class="ops-card"><h2 class="h5">Followed wards</h2><p>@string.Join(", ", Model.FollowedWards)</p></div><div class="ops-card"><h2 class="h5">WhatsApp status</h2><p><span class="badge bg-info">@Model.WhatsAppStatus</span></p></div></div>
</div>
