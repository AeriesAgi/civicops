@model CivicOps.Models.ResidentUser
@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold">
                        <i class="bi bi-person me-2"></i>My Profile
                    </h2>
                    <p class="text-muted">Manage your account and preferences</p>
                </div>
                <div>
                    <a href="@Url.Action("MyReports", "Resident")" class="btn btn-outline-primary">
                        <i class="bi bi-file-text me-2"></i>My Reports
                    </a>
                    <a href="@Url.Action("MyAlerts", "Resident")" class="btn btn-outline-info">
                        <i class="bi bi-bell me-2"></i>My Alerts
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@ViewBag.Success
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-person-circle display-1 text-primary"></i>
                    </div>
                    <h4 class="mb-1">@Model.FullName</h4>
                    <p class="text-muted mb-2">@Model.Email</p>
                    <p class="text-muted small">
                        <i class="bi bi-calendar me-1"></i>
                        Member since @Model.CreatedAt.ToString("MMMM yyyy")
                    </p>
                    <hr>
                    <div class="d-grid gap-2">
                        <form method="post" asp-action="Logout" asp-controller="Resident">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-bar-chart me-2"></i>Account Stats
                    </h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="bi bi-file-text text-primary me-2"></i>
                            <strong>@Model.SubmittedReportReferences.Count</strong> Reports Submitted
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-geo-alt text-info me-2"></i>
                            <strong>@Model.FollowedSuburbs.Count</strong> Suburbs Followed
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-pin-map text-secondary me-2"></i>
                            <strong>@Model.FollowedWards.Count</strong> Wards Followed
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Update Profile</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="UpdateProfile" asp-controller="Resident">
                        <div class="mb-3">
                            <label for="fullName" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="fullName" name="fullName" value="@Model.FullName" required>
                        </div>

                        <div class="mb-3">
                            <label for="phoneNumber" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber" value="@Model.PhoneNumber" placeholder="+27 82 *** 4567">
                            <small class="text-muted">For SMS notifications (optional)</small>
                        </div>

                        <hr>

                        <h6 class="mb-3"><i class="bi bi-bell me-2"></i>Notification Preferences</h6>

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="emailNotifications" name="emailNotifications" @(Model.EmailNotifications ? "checked" : "")>
                            <label class="form-check-label" for="emailNotifications">
                                <i class="bi bi-envelope me-1"></i>Email Notifications
                            </label>
                        </div>

                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="smsNotifications" name="smsNotifications" @(Model.SMSNotifications ? "checked" : "")>
                            <label class="form-check-label" for="smsNotifications">
                                <i class="bi bi-phone me-1"></i>SMS Notifications
                            </label>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="alertNotifications" name="alertNotifications" @(Model.AlertNotifications ? "checked" : "")>
                            <label class="form-check-label" for="alertNotifications">
                                <i class="bi bi-bell me-1"></i>Area Alert Notifications
                            </label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Followed Areas</h5>
                </div>
                <div class="card-body">
                    <h6 class="mb-3">Suburbs</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (Model.FollowedSuburbs.Any())
                        {
                            @foreach (var suburb in Model.FollowedSuburbs)
                            {
                                <span class="badge bg-info">
                                    @suburb
                                    <button type="button" class="btn-close btn-close-white ms-2" style="font-size: 0.6rem;" onclick="removeArea('suburb', '@suburb')"></button>
                                </span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No suburbs followed</span>
                        }
                    </div>

                    <h6 class="mb-3">Wards</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @if (Model.FollowedWards.Any())
                        {
                            @foreach (var ward in Model.FollowedWards)
                            {
                                <span class="badge bg-secondary">
                                    @ward
                                    <button type="button" class="btn-close btn-close-white ms-2" style="font-size: 0.6rem;" onclick="removeArea('ward', '@ward')"></button>
                                </span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No wards followed</span>
                        }
                    </div>

                    <hr>

                    <h6 class="mb-3">Add Area to Follow</h6>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <select class="form-select" id="areaType">
                                <option value="suburb">Suburb</option>
                                <option value="ward">Ward</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <input type="text" class="form-control" id="areaValue" placeholder="Enter suburb or ward name">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-primary w-100" onclick="addArea()">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    </div>

                    <div class="alert alert-info mt-3 mb-0">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            Follow suburbs and wards to receive alerts for those areas.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function addArea() {
        const areaType = document.getElementById('areaType').value;
        const areaValue = document.getElementById('areaValue').value.trim();
        
        if (!areaValue) {
            alert('Please enter an area name');
            return;
        }

        fetch('@Url.Action("AddFollowedArea", "Resident")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `areaType=${areaType}&areaValue=${encodeURIComponent(areaValue)}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to add area: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred');
        });
    }

    function removeArea(areaType, areaValue) {
        if (!confirm(`Remove ${areaValue} from followed areas?`)) {
            return;
        }

        fetch('@Url.Action("RemoveFollowedArea", "Resident")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `areaType=${areaType}&areaValue=${encodeURIComponent(areaValue)}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to remove area: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred');
        });
    }
</script>
