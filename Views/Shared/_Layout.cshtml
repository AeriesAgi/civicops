<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CivicOps</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/civicops-theme.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #0a1929 0%, #1a2332 100%);
            color: #e0e7ff;
            min-height: 100vh;
        }
        
        .navbar {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(10px);
            padding: 1rem 2rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        
        .navbar-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .navbar-brand {
            font-size: 1.5rem;
            font-weight: bold;
            color: #06b6d4;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .navbar-brand:hover {
            color: #22d3ee;
        }
        
        .navbar-menu {
            display: flex;
            gap: 1.5rem;
            list-style: none;
            flex-wrap: wrap;
        }
        
        .navbar-menu a {
            color: #cbd5e1;
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            transition: all 0.2s;
        }
        
        .navbar-menu a:hover {
            background: rgba(6, 182, 212, 0.1);
            color: #06b6d4;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        .card {
            background: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(10px);
            border-radius: 0.75rem;
            padding: 2rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(6, 182, 212, 0.2);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
        }
        
        .card-title {
            font-size: 1.5rem;
            font-weight: bold;
            color: #06b6d4;
            margin-bottom: 1rem;
        }
        
        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            border: none;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
            color: white;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #0891b2 0%, #0e7490 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.4);
        }
        
        .btn-secondary {
            background: rgba(100, 116, 139, 0.3);
            color: #e0e7ff;
            border: 1px solid rgba(148, 163, 184, 0.3);
        }
        
        .btn-secondary:hover {
            background: rgba(100, 116, 139, 0.5);
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            color: #cbd5e1;
            font-weight: 500;
        }
        
        .form-control {
            width: 100%;
            padding: 0.75rem;
            border-radius: 0.5rem;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(15, 23, 42, 0.6);
            color: #e0e7ff;
            font-size: 1rem;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #06b6d4;
            box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.1);
        }
        
        textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }
        
        .alert {
            padding: 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
        }
        
        .alert-warning {
            background: rgba(251, 191, 36, 0.1);
            border: 1px solid rgba(251, 191, 36, 0.3);
            color: #fbbf24;
        }
        
        .alert-success {
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.3);
            color: #22c55e;
        }
        
        .alert-danger {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #ef4444;
        }
        
        .footer {
            background: rgba(15, 23, 42, 0.95);
            padding: 2rem;
            margin-top: 4rem;
            text-align: center;
            color: #94a3b8;
        }
        
        @@media (max-width: 768px) {
            .navbar-container {
                flex-direction: column;
                gap: 1rem;
            }
            
            .navbar-menu {
                width: 100%;
                justify-content: center;
            }
            
            .container {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="bi bi-building"></i> CivicOps
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house-door me-1"></i>Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Report"><i class="bi bi-file-earmark-plus me-1"></i>Report Issue</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Lookup"><i class="bi bi-search me-1"></i>Track Report</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Alerts"><i class="bi bi-exclamation-triangle me-1"></i>Alerts</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Mobile"><i class="bi bi-phone me-1"></i>Mobile</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Agent"><i class="bi bi-robot me-1"></i>AI Agent</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @if (Context.Session.GetString("UserEmail") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Connectors"><i class="bi bi-plug me-1"></i>Connectors</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UserEmail")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-item-text small">Role: @Context.Session.GetString("UserRole")</span></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-controller="Auth" asp-action="Logout" class="d-inline">
                                        <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else if (Context.Session.GetString("ResidentUserId") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Resident/MyReports"><i class="bi bi-file-text me-1"></i>My Reports</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Resident/MyAlerts"><i class="bi bi-bell me-1"></i>My Alerts</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="residentDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("ResidentUserName")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Resident/Profile"><i class="bi bi-person me-1"></i>Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-controller="Resident" asp-action="Logout" class="d-inline">
                                        <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Resident/Login"><i class="bi bi-person me-1"></i>Resident Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Auth/Login"><i class="bi bi-shield-lock me-1"></i>Staff Login</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <p class="mb-1">&copy; 2026 CivicOps - Civic Operations Platform</p>
                    <p class="small mb-0">Integration-Ready Municipal Operations System</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-1">
                        <a href="/Home/Report" class="me-3">Report Issue</a>
                        <a href="/Home/Lookup" class="me-3">Track Report</a>
                        <a href="/Home/Alerts">View Alerts</a>
                    </p>
                    <p class="small mb-0">
                        <i class="bi bi-shield-check me-1"></i>
                        <strong>Emergency:</strong> Call 10111 (Police) or 10177 (Fire/Ambulance)
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>