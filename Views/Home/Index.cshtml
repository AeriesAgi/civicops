@{
    ViewData["Title"] = "CivicOps Civic Intelligence";
}

<div class="container py-4 civic-page">
    <section class="hero-panel mb-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="eyebrow">Hackathon submission · live connector-ready</span>
                <h1 class="display-4 fw-bold">Messy resident reports become structured civic intelligence.</h1>
                <p class="lead">CivicOps validates, classifies, routes, acknowledges, and audits reports from web forms, WhatsApp, mobile/PWA, and voice-note transcripts.</p>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a class="btn btn-primary btn-lg" href="/Home/DemoTour">Start Judge Tour</a>
                    <a class="btn btn-outline-info btn-lg" href="/Home/Report">Report Issue</a>
                    <a class="btn btn-outline-light btn-lg" href="/Home/Agent">Open AI Agent</a>
                    <a class="btn btn-success btn-lg" href="/Demo/WhatsAppSimulator">WhatsApp Intake Sandbox</a>
                    <a class="btn btn-outline-warning btn-lg" href="/Home/Connectors">View Connectors</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="ops-card mb-0">
                    <h2 class="h4">Operational flow</h2>
                    <ol class="timeline-list">
                        <li>Resident sends messy report</li>
                        <li>AI/fallback validates and classifies</li>
                        <li>Department queue receives routed ticket</li>
                        <li>Citizen receives reference and status path</li>
                        <li>Alerts, weather, and dashboards improve area awareness</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-md-6 col-xl-3"><div class="ops-card h-100"><i class="bi bi-inboxes fs-1 text-info"></i><h3 class="h5 mt-3">Multi-channel intake</h3><p class="text-muted-strong">Web, WhatsApp, mobile/API, and voice transcript flows use the shared intake service.</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="ops-card h-100"><i class="bi bi-cpu fs-1 text-info"></i><h3 class="h5 mt-3">AI + deterministic fallback</h3><p class="text-muted-strong">Gemini activates live when configured; fallback remains reliable for judging without secrets.</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="ops-card h-100"><i class="bi bi-diagram-3 fs-1 text-info"></i><h3 class="h5 mt-3">Routing and audit</h3><p class="text-muted-strong">Departments get queues, citizens get references, and audit notes preserve human oversight.</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="ops-card h-100"><i class="bi bi-cloud-sun fs-1 text-info"></i><h3 class="h5 mt-3">Area awareness</h3><p class="text-muted-strong">Weather and alert context helps operations teams understand clusters and risk.</p></div></div>
    </div>

    <div class="alert alert-info mt-4">CivicOps uses synthetic scenario data for judging. Live integrations are activated through configured connector credentials. No official municipal partnership is claimed, and CivicOps is not an emergency services replacement.</div>
</div>
