@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="container position-relative">
        <div class="row align-items-center py-5">
            <div class="col-lg-7">
                <h1 class="hero-title mb-4">
                    <i class="bi bi-building me-3"></i>CivicOps
                </h1>
                <p class="hero-subtitle mb-4">
                    Integration-Ready Civic Operations Platform for Municipal Incident Intake, AI-Powered Routing, and Public Tracking
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Home/Report" class="btn btn-primary btn-lg">
                        <i class="bi bi-file-earmark-plus me-2"></i>Report an Issue
                    </a>
                    <a href="/Home/Lookup" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-search me-2"></i>Track Your Report
                    </a>
                    <a href="/Home/Alerts" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-exclamation-triangle me-2"></i>View Alerts
                    </a>
                </div>
            </div>
            <div class="col-lg-5 text-center mt-4 mt-lg-0">
                <div class="feature-icon" style="font-size: 8rem; opacity: 0.3;">
                    <i class="bi bi-diagram-3"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Emergency Disclaimer -->
<div class="container mt-4">
    <div class="emergency-disclaimer">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="disclaimer-icon">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
            </div>
            <div class="col">
                <h5 class="mb-2"><strong>Emergency Disclaimer</strong></h5>
                <p class="mb-0">
                    <strong>If you or someone else is in immediate danger, please contact official emergency services directly:</strong>
                    Police: <strong>10111</strong> | Fire/EMS: <strong>10177</strong>
                    <br>
                    CivicOps is for non-emergency civic issues only and does not replace official emergency response systems.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Problem Statement -->
<div class="container my-5">
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="text-center mb-5">
                <h2 class="text-navy fw-bold mb-3">The Challenge</h2>
                <p class="lead text-muted">
                    Municipal governments face fragmented citizen reporting channels, slow manual routing, 
                    and limited public visibility into incident resolution. CivicOps solves this.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Solution Features -->
<div class="container my-5">
    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-phone"></i>
                    </div>
                    <h4 class="text-navy fw-bold mb-3">Multi-Channel Intake</h4>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Web/PWA reporting</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Android mobile app</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>WhatsApp text intake</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Voice note support</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Photo/media attachments</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-robot"></i>
                    </div>
                    <h4 class="text-navy fw-bold mb-3">AI-Powered Classification</h4>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Gemini AI integration</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Smart categorization</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Auto department routing</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Priority assignment</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Deterministic fallback</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <h4 class="text-navy fw-bold mb-3">Department Operations</h4>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Department queues</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Incident management</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Status workflows</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Internal notes</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Escalation support</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-eye"></i>
                    </div>
                    <h4 class="text-navy fw-bold mb-3">Public Transparency</h4>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Reference tracking</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Status updates</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Public timeline</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Area-based alerts</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Department visibility</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <h4 class="text-navy fw-bold mb-3">13 Municipal Departments</h4>
                    <ul class="list-unstyled small">
                        <li><i class="bi bi-droplet-fill text-cyan me-2"></i>Water & Sanitation</li>
                        <li><i class="bi bi-lightning-fill text-warning me-2"></i>Electricity</li>
                        <li><i class="bi bi-sign-turn-right-fill text-secondary me-2"></i>Roads & Stormwater</li>
                        <li><i class="bi bi-trash-fill text-success me-2"></i>Waste Management</li>
                        <li><i class="bi bi-fire text-danger me-2"></i>Fire & Rescue</li>
                        <li class="text-muted">+ 8 more departments</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <div class="feature-icon">
                        <i class="bi bi-plug"></i>
                    </div>
                    <h4 class="text-navy fw-bold mb-3">Integration Ready</h4>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>WhatsApp Cloud API</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Voice transcription</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>SMS notifications</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>GIS/mapping</li>
                        <li><i class="bi bi-check-circle-fill text-teal me-2"></i>Municipal ERP</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- How It Works -->
<div class="bg-light py-5 my-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="text-navy fw-bold mb-3">How CivicOps Works</h2>
            <p class="lead text-muted">Simple, transparent, and efficient civic operations</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="text-center">
                    <div class="bg-cyan text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        1
                    </div>
                    <h5 class="text-navy fw-bold mb-2">Report Issue</h5>
                    <p class="text-muted">
                        Residents report civic issues via web, mobile, or WhatsApp. Describe the problem and location.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="text-center">
                    <div class="bg-teal text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        2
                    </div>
                    <h5 class="text-navy fw-bold mb-2">AI Classification</h5>
                    <p class="text-muted">
                        CivicOps uses Gemini AI or deterministic rules to classify, route to the correct department, and set priority.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="text-center">
                    <div class="bg-cyan text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        3
                    </div>
                    <h5 class="text-navy fw-bold mb-2">Get Reference</h5>
                    <p class="text-muted">
                        Receive a unique reference number (e.g., CIV-2026-0001) to track your report's progress.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="text-center">
                    <div class="bg-teal text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        4
                    </div>
                    <h5 class="text-navy fw-bold mb-2">Department Action</h5>
                    <p class="text-muted">
                        Assigned department reviews, updates status, and takes action to resolve the issue.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="text-center">
                    <div class="bg-cyan text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        5
                    </div>
                    <h5 class="text-navy fw-bold mb-2">Track Progress</h5>
                    <p class="text-muted">
                        Use your reference number to check status updates and see when the issue is resolved.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="text-center">
                    <div class="bg-teal text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                         style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                        6
                    </div>
                    <h5 class="text-navy fw-bold mb-2">Public Updates</h5>
                    <p class="text-muted">
                        Receive public updates throughout the lifecycle. View area alerts for broader issues.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Integration Readiness -->
<div class="container my-5">
    <div class="card border-0 shadow-lg">
        <div class="card-body p-5">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h3 class="text-navy fw-bold mb-3">
                        <i class="bi bi-plug-fill text-teal me-2"></i>Built for Integration
                    </h3>
                    <p class="lead mb-3">
                        CivicOps is designed as a connector-ready platform. While it works fully in demo mode, 
                        it's architected for production integration.
                    </p>
                    <p class="text-muted mb-0">
                        Each connector has a clear interface, environment variable configuration, and documentation 
                        for production deployment. Connect to WhatsApp Cloud API, voice transcription services, 
                        SMS gateways, GIS/mapping systems, municipal ERP platforms, and authentication systems.
                    </p>
                </div>
                <div class="col-lg-4 text-center mt-4 mt-lg-0">
                    <a href="/Home/Connectors" class="btn btn-primary btn-lg">
                        <i class="bi bi-plug me-2"></i>View Connectors
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="bg-navy text-white py-5 my-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-4">Ready to Transform Civic Operations?</h2>
        <p class="lead mb-4">
            Start reporting issues, track progress, and see how CivicOps streamlines municipal operations.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Home/Report" class="btn btn-primary btn-lg">
                <i class="bi bi-file-earmark-plus me-2"></i>Report an Issue
            </a>
            <a href="/Auth/Login" class="btn btn-outline-light btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i>Demo Login
            </a>
            <a href="/Home/Mobile" class="btn btn-outline-light btn-lg">
                <i class="bi bi-phone me-2"></i>Mobile Access
            </a>
        </div>
    </div>
</div>

<!-- Disclaimer -->
<div class="container my-5">
    <div class="text-center text-muted small">
        <p class="mb-2">
            <i class="bi bi-info-circle me-1"></i>
            <strong>Demo Platform:</strong> CivicOps is a demonstration platform showcasing integration-ready civic operations technology.
        </p>
        <p class="mb-0">
            Not affiliated with any official municipal government. Does not replace official emergency services.
            For emergencies, always contact Police (10111) or Fire/EMS (10177) directly.
        </p>
    </div>
</div>
