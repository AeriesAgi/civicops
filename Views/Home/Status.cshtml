@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Report Status - " + Model.ReferenceNumber;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Card -->
            <div class="card mb-4">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h1 class="text-navy fw-bold mb-2">
                                <i class="bi bi-file-earmark-text me-2"></i>Report Status
                            </h1>
                            <div class="d-flex align-items-center gap-3 flex-wrap">
                                <code class="fs-4 text-cyan fw-bold">@Model.ReferenceNumber</code>
                                <span class="badge badge-source-@Model.SourceChannel.ToString().ToLower()">
                                    @Model.SourceChannel
                                </span>
                            </div>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            <div class="d-inline-block">
                                <div class="text-muted small mb-1">Current Status</div>
                                <span class="badge badge-status-@Model.Status.ToString().ToLower() fs-5">
                                    @Model.Status
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Key Information -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-2">
                                <i class="bi bi-building me-1"></i>Department
                            </div>
                            <div class="text-navy fw-bold">@Model.AssignedDepartment.GetDisplayName()</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-2">
                                <i class="bi bi-tag me-1"></i>Category
                            </div>
                            <div class="text-navy fw-bold">@Model.Category</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-2">
                                <i class="bi bi-flag me-1"></i>Priority
                            </div>
                            <span class="badge badge-priority-@Model.Priority.ToString().ToLower() fs-6">
                                @Model.Priority
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Location & Time -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-2">
                                <i class="bi bi-geo-alt me-1"></i>Suburb
                            </div>
                            <div class="text-navy fw-bold">@Model.Suburb</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-2">
                                <i class="bi bi-pin-map me-1"></i>Ward
                            </div>
                            <div class="text-navy fw-bold">@Model.Ward</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-2">
                                <i class="bi bi-clock me-1"></i>Reported
                            </div>
                            <div class="text-navy fw-bold">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-file-text me-2"></i>Issue Description
                </div>
                <div class="card-body">
                    <p class="mb-0 text-navy">@Model.Description</p>
                    @if (!string.IsNullOrEmpty(Model.AISummary))
                    {
                        <hr class="my-3">
                        <div class="small">
                            <div class="text-muted mb-2">
                                <i class="bi bi-robot me-1"></i>AI Summary
                            </div>
                            <p class="mb-0 text-navy">@Model.AISummary</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Timeline / Updates -->
            @if (Model.PublicUpdates.Any())
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-clock-history me-2"></i>Public Updates
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            @foreach (var update in Model.PublicUpdates.AsEnumerable().Reverse())
                            {
                                <div class="timeline-item timeline-public">
                                    <div class="timeline-content">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                @update.Timestamp.ToString("MMM dd, yyyy HH:mm")
                                            </small>
                                            @if (!string.IsNullOrEmpty(update.UpdatedBy))
                                            {
                                                <small class="text-muted">
                                                    <i class="bi bi-person me-1"></i>@update.UpdatedBy
                                                </small>
                                            }
                                        </div>
                                        <p class="mb-0 text-navy">@update.Content</p>
                                        @if (update.RelatedStatus.HasValue)
                                        {
                                            <div class="mt-2">
                                                <span class="badge badge-status-@update.RelatedStatus.Value.ToString().ToLower() small">
                                                    Status: @update.RelatedStatus.Value
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card mb-4">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-hourglass-split text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-3 mb-0">No updates yet. We'll notify you when there's progress on your report.</p>
                    </div>
                </div>
            }

            <!-- Emergency Disclaimer -->
            <div class="emergency-disclaimer mb-4">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <div class="disclaimer-icon">
                            <i class="bi bi-shield-exclamation"></i>
                        </div>
                    </div>
                    <div class="col">
                        <h6 class="mb-2"><strong>Emergency Reminder</strong></h6>
                        <p class="mb-0 small">
                            If this is an emergency or someone is in immediate danger, please contact official emergency services directly:
                            <strong>Police: 10111</strong> | <strong>Fire/EMS: 10177</strong>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-3 flex-wrap">
                <a href="/Home/Lookup" class="btn btn-primary">
                    <i class="bi bi-search me-2"></i>Track Another Report
                </a>
                <a href="/Home/Report" class="btn btn-outline-primary">
                    <i class="bi bi-file-earmark-plus me-2"></i>Report New Issue
                </a>
                <a href="/Home/Alerts" class="btn btn-outline-secondary">
                    <i class="bi bi-exclamation-triangle me-2"></i>View Area Alerts
                </a>
                <a href="/" class="btn btn-outline-secondary">
                    <i class="bi bi-house me-2"></i>Back to Home
                </a>
            </div>

            <!-- Additional Info -->
            <div class="card mt-4 bg-light border-0">
                <div class="card-body">
                    <h6 class="text-navy fw-bold mb-3">What happens next?</h6>
                    <ul class="mb-0 text-muted small">
                        <li>Your report has been assigned to the <strong>@Model.AssignedDepartment.GetDisplayName()</strong> department</li>
                        <li>The department will review and prioritize your report based on urgency and resources</li>
                        <li>You can check this page anytime using your reference number: <code class="text-cyan">@Model.ReferenceNumber</code></li>
                        <li>Public updates will appear in the timeline above as the department works on your issue</li>
                        <li>Keep your reference number safe for future tracking</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>