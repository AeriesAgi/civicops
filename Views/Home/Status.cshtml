@model CivicOps.Models.Incident?
@{
    ViewData["Title"] = Model == null ? "Reference Not Found" : "Report Status";
    var canSeeAudit = (ViewBag.CanSeeAudit as bool?) ?? false;
}
<div class="container py-4 civic-page">
@if (Model == null)
{
  <section class="hero-panel mb-4"><span class="eyebrow">Reference not found</span><h1 class="display-5">We could not find that reference</h1><p class="lead">Reference @(ViewBag.Reference ?? "not supplied") was not found in the current CivicOps synthetic scenario data.</p><div class="d-flex gap-2 flex-wrap"><a class="btn btn-primary" href="/Home/Lookup">Track Reference</a><a class="btn btn-outline-info" href="/Home/Report">Report Issue</a><a class="btn btn-outline-light" href="/app">Open Citizen App</a></div></section>
}
else
{
  var latestResponse = Model.PublicUpdates.LastOrDefault()?.Content ?? Model.CitizenResponse ?? "No citizen response recorded.";
  <section class="hero-panel mb-4"><span class="eyebrow">Public reference</span><h1 class="display-5">@Model.ReferenceNumber</h1><p class="lead">Status: <span class="badge bg-info">@Model.Status</span> Department: <span class="badge bg-info">@Model.AssignedDepartment.GetDisplayName()</span> Priority: <span class="badge bg-warning">@Model.Priority</span></p><div class="d-flex gap-2 flex-wrap"><a class="btn btn-primary" href="/Home/Lookup">Track another reference</a><a class="btn btn-outline-info" href="/Home/Alerts?suburb=@Uri.EscapeDataString(Model.NormalizedArea)">View Area Alerts</a><a class="btn btn-outline-light" href="/app">Open Citizen App</a><a class="btn btn-outline-warning" href="/app/incident/@Model.ReferenceNumber">Community Thread</a></div></section>
  <div class="row g-4">
    <div class="col-lg-5"><div class="ops-card"><h2 class="h4">Ticket summary</h2><dl><dt>Category</dt><dd>@Model.Category</dd><dt>Original area</dt><dd>@Model.OriginalArea</dd><dt>Normalized area</dt><dd>@Model.NormalizedArea</dd><dt>Ward / estimate</dt><dd>@Model.Ward <span class="badge bg-info">@Model.WardConfidence</span></dd><dt>Created</dt><dd>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd><dt>Latest update</dt><dd>@Model.LastUpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd><dt>AI/fallback source</dt><dd>@Model.EnrichmentSource</dd></dl><p>@Model.AISummary</p><h3 class="h5">Latest citizen response</h3><p>@latestResponse</p></div></div>
    <div class="col-lg-7"><div class="ops-card"><h2 class="h4">Public timeline</h2>@if (Model.PublicUpdates.Any()) { <ol class="timeline-list">@foreach (var update in Model.PublicUpdates.OrderByDescending(u => u.Timestamp)) { <li><strong>@update.Timestamp.ToString("MMM dd HH:mm")</strong> — @update.Content <span class="text-muted-strong">(@update.UpdatedBy)</span></li> }</ol> } else { <div class="alert alert-info">No public updates yet.</div> }</div><div class="ops-card mt-4"><h2 class="h4">Community Thread</h2><p>Residents in @Model.NormalizedArea can add local confirmations and follow status changes for @Model.ReferenceNumber.</p><ul class="timeline-list"><li><strong>Resident</strong> — “Also affected nearby; following this reference.”</li><li><strong>Moderation note</strong> — Keep comments factual and do not post personal data.</li></ul><div class="d-flex gap-2 flex-wrap"><a class="btn btn-outline-warning" href="/app/incident/@Model.ReferenceNumber">Open incident thread</a><a class="btn btn-outline-info" href="/app/area/@Uri.EscapeDataString(Model.NormalizedArea)/thread">Open area thread</a></div></div>@if (canSeeAudit) { <div class="ops-card mt-4"><h2 class="h4">Staff audit notes</h2><ol class="timeline-list">@foreach (var note in Model.InternalNotes.OrderByDescending(n => n.Timestamp)) { <li><strong>@note.Timestamp.ToString("MMM dd HH:mm")</strong> — @note.Content</li> }</ol></div> }</div>
  </div>
}
</div>
