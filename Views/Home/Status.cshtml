@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Report Status";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Public reference</span><h1 class="display-5">@Model.ReferenceNumber</h1><p class="lead">Status: <span class="badge bg-info">@Model.Status</span> Department: <span class="badge bg-info">@Model.AssignedDepartment.GetDisplayName()</span> Priority: <span class="badge bg-warning">@Model.Priority</span></p></section>
  <div class="row g-4">
    <div class="col-lg-5"><div class="ops-card"><h2 class="h4">Ticket summary</h2><dl><dt>Category</dt><dd>@Model.Category</dd><dt>Area</dt><dd>@Model.Suburb · @Model.Ward</dd><dt>Created</dt><dd>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd><dt>Latest update</dt><dd>@Model.LastUpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd><dt>AI source</dt><dd>@Model.ClassificationMethod</dd></dl><p>@Model.AISummary</p></div></div>
    <div class="col-lg-7"><div class="ops-card"><h2 class="h4">Public timeline</h2>@if (Model.PublicUpdates.Any()) { <ol class="timeline-list">@foreach (var update in Model.PublicUpdates.OrderByDescending(u => u.Timestamp)) { <li><strong>@update.Timestamp.ToString("MMM dd HH:mm")</strong> — @update.Content <span class="text-muted-strong">(@update.UpdatedBy)</span></li> }</ol> } else { <div class="alert alert-info">No public updates yet.</div> }<a href="/Home/Lookup" class="btn btn-outline-info mt-3">Lookup another reference</a></div></div>
  </div>
</div>
