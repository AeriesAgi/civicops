@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Report Status";
}

<div class="container">
    <div class="card" style="max-width: 900px; margin: 2rem auto;">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h1 class="card-title">Report Status</h1>
                <div style="font-size: 1.5rem; font-family: monospace; color: #06b6d4; margin-top: 0.5rem;">
                    @Model.ReferenceNumber
                </div>
            </div>
            <div style="text-align: right;">
                <div style="display: inline-block; padding: 0.5rem 1rem; background: rgba(6, 182, 212, 0.2); border-radius: 0.5rem; border: 1px solid rgba(6, 182, 212, 0.3);">
                    <div style="font-size: 0.875rem; color: #94a3b8;">Status</div>
                    <div style="font-size: 1.25rem; font-weight: bold; color: #06b6d4;">@Model.Status</div>
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.25rem;">Department</div>
                <div style="color: #e0e7ff; font-weight: 600;">@Model.AssignedDepartment.GetDisplayName()</div>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.25rem;">Category</div>
                <div style="color: #e0e7ff; font-weight: 600;">@Model.Category</div>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.25rem;">Priority</div>
                <div style="color: #e0e7ff; font-weight: 600;">@Model.Priority</div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.25rem;">Suburb</div>
                <div style="color: #e0e7ff; font-weight: 600;">@Model.Suburb</div>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.25rem;">Ward</div>
                <div style="color: #e0e7ff; font-weight: 600;">@Model.Ward</div>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <div style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.25rem;">Reported</div>
                <div style="color: #e0e7ff; font-weight: 600;">@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
        </div>

        <div style="margin-bottom: 2rem;">
            <h3 style="color: #cbd5e1; margin-bottom: 1rem;">Description</h3>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem; color: #e0e7ff; line-height: 1.6;">
                @Model.Description
            </div>
        </div>

        @if (Model.PublicUpdates.Any())
        {
            <div style="margin-bottom: 2rem;">
                <h3 style="color: #cbd5e1; margin-bottom: 1rem;">Updates</h3>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    @foreach (var update in Model.PublicUpdates.AsEnumerable().Reverse())
                    {
                        <div style="padding: 1rem; background: rgba(6, 182, 212, 0.1); border-left: 4px solid #06b6d4; border-radius: 0.5rem;">
                            <p style="color: #e0e7ff; margin: 0;">@update</p>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="alert alert-warning">
            <strong>Important:</strong> If this is an emergency or someone is in immediate danger, please contact official emergency services directly (Police: 10111, Fire/EMS: 10177).
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="/Home/Lookup" class="btn btn-secondary">
                Track Another Report
            </a>
            <a href="/" class="btn btn-secondary">
                Back to Home
            </a>
        </div>
    </div>
</div>
