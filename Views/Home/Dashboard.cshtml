@model CivicOps.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container">
    <h1 style="color: #06b6d4; margin-bottom: 2rem;">📊 CivicOps Dashboard</h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #06b6d4;">@Model.TotalIncidents</div>
            <div style="color: #94a3b8; margin-top: 0.5rem;">Total Incidents</div>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #fbbf24;">@Model.NewIncidents</div>
            <div style="color: #94a3b8; margin-top: 0.5rem;">New</div>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #3b82f6;">@Model.InProgressIncidents</div>
            <div style="color: #94a3b8; margin-top: 0.5rem;">In Progress</div>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #ef4444;">@Model.EscalatedIncidents</div>
            <div style="color: #94a3b8; margin-top: 0.5rem;">Escalated</div>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; font-weight: bold; color: #22c55e;">@Model.ResolvedIncidents</div>
            <div style="color: #94a3b8; margin-top: 0.5rem;">Resolved</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem;">
        <div class="card">
            <h2 class="card-title">Incidents by Department</h2>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                @foreach (var dept in Model.IncidentsByDepartment)
                {
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                        <a href="/Home/Department?dept=@dept.Department" style="color: #e0e7ff; text-decoration: none; flex: 1;">
                            @dept.Department.GetDisplayName()
                        </a>
                        <span style="background: rgba(6, 182, 212, 0.2); color: #06b6d4; padding: 0.25rem 0.75rem; border-radius: 1rem; font-weight: 600;">
                            @dept.Count
                        </span>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <h2 class="card-title">Incidents by Source</h2>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                @foreach (var source in Model.IncidentsBySource)
                {
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                        <span style="color: #e0e7ff;">
                            @(source.Source == CivicOps.Models.SourceChannel.Web ? "🌐 Web" :
                              source.Source == CivicOps.Models.SourceChannel.Android ? "📱 Android" :
                              source.Source == CivicOps.Models.SourceChannel.WhatsApp ? "💬 WhatsApp" :
                              source.Source == CivicOps.Models.SourceChannel.VoiceNote ? "🎤 Voice Note" : "Demo")
                        </span>
                        <span style="background: rgba(6, 182, 212, 0.2); color: #06b6d4; padding: 0.25rem 0.75rem; border-radius: 1rem; font-weight: 600;">
                            @source.Count
                        </span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem; margin-top: 1.5rem;">
        <div class="card">
            <h2 class="card-title">High Priority Incidents</h2>
            @if (Model.HighPriorityIncidents.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    @foreach (var incident in Model.HighPriorityIncidents)
                    {
                        <a href="/Home/Incident?id=@incident.Id" style="text-decoration: none;">
                            <div style="padding: 1rem; background: rgba(239, 68, 68, 0.1); border-left: 4px solid #ef4444; border-radius: 0.5rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-family: monospace; color: #06b6d4; font-weight: 600;">@incident.ReferenceNumber</span>
                                    <span style="color: #ef4444; font-weight: 600;">@incident.Priority</span>
                                </div>
                                <div style="color: #e0e7ff; font-size: 0.875rem;">@incident.AISummary</div>
                                <div style="color: #94a3b8; font-size: 0.75rem; margin-top: 0.5rem;">
                                    @incident.AssignedDepartment.GetDisplayName() • @incident.Suburb
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <p style="color: #94a3b8;">No high priority incidents</p>
            }
        </div>

        <div class="card">
            <h2 class="card-title">Recent Incidents</h2>
            @if (Model.RecentIncidents.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    @foreach (var incident in Model.RecentIncidents.Take(5))
                    {
                        <a href="/Home/Incident?id=@incident.Id" style="text-decoration: none;">
                            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                    <span style="font-family: monospace; color: #06b6d4; font-weight: 600;">@incident.ReferenceNumber</span>
                                    <span style="color: #94a3b8; font-size: 0.875rem;">@incident.Status</span>
                                </div>
                                <div style="color: #e0e7ff; font-size: 0.875rem;">@incident.Category</div>
                                <div style="color: #94a3b8; font-size: 0.75rem; margin-top: 0.5rem;">
                                    @incident.AssignedDepartment.GetDisplayName() • @incident.Suburb
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <p style="color: #94a3b8;">No recent incidents</p>
            }
        </div>
    </div>

    <div class="card" style="margin-top: 1.5rem;">
        <h2 class="card-title">System Status</h2>
        <div style="display: grid; gap: 0.75rem;">
            <div style="display: flex; justify-content: space-between; padding: 0.75rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <span style="color: #cbd5e1;">Gemini AI Status:</span>
                <span style="color: #06b6d4; font-weight: 600;">@Model.GeminiStatus</span>
            </div>
            <div style="display: flex; justify-content: space-between; padding: 0.75rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <span style="color: #cbd5e1;">Active Alerts:</span>
                <span style="color: #06b6d4; font-weight: 600;">@Model.ActiveAlerts</span>
            </div>
        </div>
    </div>
</div>
