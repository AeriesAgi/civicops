@model CivicOps.Controllers.ReportViewModel
@{
    ViewData["Title"] = "Report Issue";
}
<div class="container py-4 civic-page">
    <section class="hero-panel mb-4">
        <span class="eyebrow">Citizen-first civic intake</span>
        <h1 class="display-5">Report a civic issue</h1>
        <p class="lead">Submit a report through the web/PWA portal. CivicOps creates a public reference, runs Gemini/fallback analysis only on submit, and routes the ticket for human review.</p>
        <div class="alert alert-warning mb-0">If there is immediate danger, contact emergency services directly. CivicOps supports civic reporting and routing; it does not replace emergency services.</div>
    </section>

    <form asp-action="Report" method="post" class="ops-card">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Name</label><input asp-for="ContactName" class="form-control" placeholder="Your name" /></div>
            <div class="col-md-6"><label class="form-label">Contact</label><input asp-for="ContactPhone" class="form-control" placeholder="Phone or WhatsApp number (optional)" /></div>
            <div class="col-md-6"><label class="form-label">Email</label><input asp-for="ContactEmail" class="form-control" placeholder="you@example.com (optional)" /></div>
            <div class="col-md-6"><label class="form-label">Area / suburb</label><input asp-for="Suburb" class="form-control" placeholder="e.g. Chatsworth" /></div>
            <div class="col-md-6"><label class="form-label">City / municipality</label><input asp-for="CityMunicipality" class="form-control" placeholder="e.g. eThekwini" /></div>
            <div class="col-md-6"><label class="form-label">Ward (optional)</label><input asp-for="Ward" class="form-control" placeholder="e.g. Ward 68" /></div>
            <div class="col-md-6"><label class="form-label">Urgency</label><select asp-for="Urgency" class="form-select"><option>Normal civic issue</option><option>High impact</option><option>Urgent civic risk</option><option>Possible emergency - also contact emergency services</option></select></div>
            <div class="col-md-6"><label class="form-label">Optional category</label><input asp-for="Category" class="form-control" placeholder="Water, electricity, road, waste..." /></div>
            <div class="col-12"><label class="form-label">Location notes</label><input asp-for="LocationNotes" class="form-control" placeholder="Nearest landmark, street, intersection or facility" /></div>
            <div class="col-12"><label class="form-label">Issue description</label><textarea asp-for="Description" class="form-control" rows="6" placeholder="Describe what happened, when it started, who is affected and any visible risks."></textarea></div>
            <div class="col-12"><label class="form-label">Photo / media</label><div class="ops-card mb-0"><span class="badge bg-secondary">Placeholder</span> Media upload is connector-ready for pilot storage; do not upload sensitive material in this sandbox scenario.</div></div>
            <div class="col-12"><div class="form-check"><input asp-for="ConsentAccepted" class="form-check-input" /><label class="form-check-label" asp-for="ConsentAccepted">I consent to CivicOps processing this synthetic/pilot report for routing and acknowledge it is not an emergency services replacement.</label><span asp-validation-for="ConsentAccepted" class="text-danger d-block"></span></div></div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-4"><button type="submit" class="btn btn-primary btn-lg">Submit and create reference</button><a href="/Home/Lookup" class="btn btn-outline-info btn-lg">Track existing reference</a><a href="/citizen-app" class="btn btn-outline-light btn-lg">Open Citizen App</a></div>
    </form>
</div>
