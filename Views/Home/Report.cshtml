@model CivicOps.Controllers.ReportViewModel
@{
    ViewData["Title"] = "Report an Issue";
}

<div class="container">
    <div class="card" style="max-width: 800px; margin: 2rem auto;">
        <h1 class="card-title">📝 Report a Civic Issue</h1>
        
        <div class="alert alert-warning">
            <strong>⚠️ Emergency Disclaimer:</strong> If you or someone else is in immediate danger, please contact official emergency services directly (Police: 10111, Fire/EMS: 10177). This form is for non-emergency civic issues only.
        </div>

        <form method="post" asp-action="Report">
            <div class="form-group">
                <label class="form-label" for="Description">Issue Description *</label>
                <textarea class="form-control" id="Description" name="Description" required 
                          placeholder="Describe the issue in detail. For example: 'Burst water pipe on Main Road causing flooding' or 'Power outage in our area since this morning'"></textarea>
                <span asp-validation-for="Description" style="color: #ef4444; font-size: 0.875rem;"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="Category">Category (Optional)</label>
                <select class="form-control" id="Category" name="Category">
                    <option value="">-- Auto-detect from description --</option>
                    <option value="Water Infrastructure">Water Infrastructure</option>
                    <option value="Sanitation">Sanitation</option>
                    <option value="Electricity">Electricity</option>
                    <option value="Road Maintenance">Road Maintenance</option>
                    <option value="Stormwater">Stormwater</option>
                    <option value="Waste Collection">Waste Collection</option>
                    <option value="Illegal Dumping">Illegal Dumping</option>
                    <option value="Parks">Parks & Public Spaces</option>
                    <option value="Fire Safety">Fire Safety</option>
                    <option value="Public Safety">Public Safety</option>
                    <option value="Environmental Hazard">Environmental Hazard</option>
                    <option value="Housing">Housing</option>
                    <option value="General">General Inquiry</option>
                </select>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label" for="Suburb">Suburb/Area</label>
                    <input type="text" class="form-control" id="Suburb" name="Suburb" 
                           placeholder="e.g., Chatsworth, Umlazi, Phoenix" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="Ward">Ward</label>
                    <input type="text" class="form-control" id="Ward" name="Ward" 
                           placeholder="e.g., Ward 73" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="LocationNotes">Location Details (Optional)</label>
                <input type="text" class="form-control" id="LocationNotes" name="LocationNotes" 
                       placeholder="e.g., Near the traffic light, opposite the school" />
            </div>

            <h3 style="color: #06b6d4; margin: 2rem 0 1rem;">Contact Information (Optional)</h3>
            <p style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 1rem;">
                Providing contact details helps us reach you for updates or clarification.
            </p>

            <div class="form-group">
                <label class="form-label" for="ContactName">Your Name</label>
                <input type="text" class="form-control" id="ContactName" name="ContactName" 
                       placeholder="Optional" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label class="form-label" for="ContactPhone">Phone Number</label>
                    <input type="tel" class="form-control" id="ContactPhone" name="ContactPhone" 
                           placeholder="Optional" />
                </div>

                <div class="form-group">
                    <label class="form-label" for="ContactEmail">Email Address</label>
                    <input type="email" class="form-control" id="ContactEmail" name="ContactEmail" 
                           placeholder="Optional" />
                </div>
            </div>

            <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
                <button type="submit" class="btn btn-primary">
                    Submit Report
                </button>
                <a href="/" class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        </form>

        <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(148, 163, 184, 0.2);">
            <h4 style="color: #cbd5e1; margin-bottom: 1rem;">Other Reporting Options</h4>
            <ul style="color: #94a3b8; line-height: 1.8;">
                <li>📱 <a href="/Home/Mobile" style="color: #06b6d4;">Download the Android app</a> for mobile reporting</li>
                <li>💬 <a href="/demo/whatsapp" style="color: #06b6d4;">Report via WhatsApp</a> (demo mode)</li>
                <li>🎤 <a href="/demo/voicenote" style="color: #06b6d4;">Submit a voice note</a> (demo mode)</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
