@{
    ViewData["Title"] = "CivicOps AI Agent";
    var diagnostics = ViewBag.GeminiDiagnostics as CivicOps.Services.GeminiDiagnostics;
}
<div class="container py-4 civic-page">
    <section class="hero-panel mb-4">
        <span class="eyebrow">Operational assistant</span>
        <h1 class="display-5">CivicOps AI Agent</h1>
        <p class="lead">Operational assistant for civic intake, triage, routing, municipal response, department briefs, citizen replies, area alerts and structured incident JSON. No Gemini call runs on page load; each button is an explicit backend action.</p>
        <div class="d-flex gap-2 flex-wrap">
            <span class="badge bg-info">Gemini enabled: @(diagnostics?.Enabled == true ? "yes" : "no")</span>
            <span class="badge bg-info">Key present: @(diagnostics?.KeyPresent == true ? "yes" : "no")</span>
            <span class="badge bg-warning">Fallback active: @(diagnostics?.FallbackActive == true ? "yes" : "ready")</span>
            <span class="badge bg-secondary">Auto-run: false</span>
        </div>
    </section>
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="ops-card mb-3">
                <h2 class="h5">Actions</h2>
                <div class="d-grid gap-2" id="agentButtons">
                    <button class="btn btn-primary agent-action" data-scenario="latest-report">Analyze selected report</button>
                    <button class="btn btn-outline-info agent-action" data-scenario="whatsapp-report">Classify issue / route department</button>
                    <button class="btn btn-outline-info agent-action" data-scenario="voice-note">Correct messy location</button>
                    <button class="btn btn-outline-warning agent-action" data-scenario="gemini-health">Run live Gemini health test</button>
                    <button class="btn btn-outline-info agent-action" data-scenario="citizen-response" data-endpoint="/api/agent/generate-response">Generate citizen response</button>
                    <button class="btn btn-outline-info agent-action" data-scenario="department-brief">Generate department brief</button>
                    <button class="btn btn-outline-info agent-action" data-scenario="area-alert" data-endpoint="/api/agent/recommend-alert">Recommend area alert</button>
                    <button class="btn btn-outline-light agent-action" data-scenario="judge-summary">Produce structured incident JSON</button>
                </div>
            </div>
            <div class="ops-card">
                <h2 class="h5">Diagnostics</h2>
                <dl class="mb-0 small">
                    <dt>Primary model</dt><dd>@(diagnostics?.PrimaryModel ?? "gemini-2.5-flash")</dd>
                    <dt>Routine model</dt><dd>@(diagnostics?.RoutineModel ?? "gemini-3.1-flash-lite")</dd>
                    <dt>Fallback models</dt><dd>@string.Join(", ", diagnostics?.FallbackModels ?? Array.Empty<string>())</dd>
                    <dt>Calls since start</dt><dd id="diagCalls">@(diagnostics?.CallsSinceAppStart ?? 0)</dd>
                    <dt>Last action/model/result</dt><dd id="diagLast">@(diagnostics?.LastCallAction ?? "None") / @(diagnostics?.LastModelUsed ?? "None") / @(diagnostics?.LastResult ?? "No calls yet")</dd>
                    <dt>Quota limited</dt><dd id="diagQuota">@(diagnostics?.QuotaLimited == true ? "yes" : "no")</dd>
                </dl>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="agent-console ops-card">
                <div class="d-flex justify-content-between align-items-center mb-3"><h2 class="h4 mb-0">Agent output</h2><span id="agentState" class="badge bg-secondary">Waiting for action</span></div>
                <div id="agentOutput" class="alert alert-info">Choose an action to run a single backend call. Results will include validation, category, department, priority, routing reason, citizen response, alert recommendation, source model/fallback and audit notes.</div>
                <h3 class="h5 mt-4">Audit trail</h3>
                <ul id="auditTrail" class="timeline-list"><li>Agent page opened; no Gemini call was triggered.</li></ul>
            </div>
        </div>
    </div>
</div>
<script>
(() => {
  const output = document.getElementById('agentOutput');
  const audit = document.getElementById('auditTrail');
  const state = document.getElementById('agentState');
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
  const render = (data) => {
    const notes = (data.auditNotes || []).map(n => `<li>${escapeHtml(n)}</li>`).join('');
    output.className = 'alert alert-info';
    output.innerHTML = `<div class="row g-3">
      <div class="col-md-6"><strong>Action</strong><br>${escapeHtml(data.action || 'Agent action')}</div>
      <div class="col-md-6"><strong>Source</strong><br>${escapeHtml(data.aiSource || data.status || 'Local deterministic fallback')}</div>
      <div class="col-md-4"><strong>Validation</strong><br>${escapeHtml(data.validation || data.message)}</div>
      <div class="col-md-4"><strong>Category</strong><br>${escapeHtml(data.category || 'Connector health')}</div>
      <div class="col-md-4"><strong>Normalized area</strong><br>${escapeHtml(data.normalizedArea || 'n/a')}</div>
      <div class="col-md-4"><strong>Ward / confidence</strong><br>${escapeHtml(data.ward || 'n/a')} ${escapeHtml(data.wardConfidence || '')}</div>
      <div class="col-md-4"><strong>Department</strong><br>${escapeHtml(data.department)}</div>
      <div class="col-md-4"><strong>Priority</strong><br>${escapeHtml(data.priority)}</div>
      <div class="col-md-8"><strong>Routing reason</strong><br>${escapeHtml(data.routingReason)}</div>
      <div class="col-12"><strong>Citizen response</strong><br>${escapeHtml(data.citizenResponse)}</div>
      <div class="col-12"><strong>Alert recommendation</strong><br>${escapeHtml(data.alertRecommendation)}</div>
      ${data.referenceNumber ? `<div class="col-12"><a class="btn btn-outline-info" href="/Home/Lookup">Track reference ${escapeHtml(data.referenceNumber)}</a></div>` : ''}
    </div>`;
    audit.insertAdjacentHTML('afterbegin', `<li><strong>${new Date().toLocaleTimeString()}</strong> ${escapeHtml(data.action || 'Action')} completed. ${notes ? `<ul>${notes}</ul>` : ''}</li>`);
    if (data.diagnostics) {
      document.getElementById('diagCalls').textContent = data.diagnostics.callsSinceAppStart;
      document.getElementById('diagLast').textContent = `${data.diagnostics.lastCallAction} / ${data.diagnostics.lastModelUsed} / ${data.diagnostics.lastResult}`;
      document.getElementById('diagQuota').textContent = data.diagnostics.quotaLimited ? 'yes' : 'no';
    }
  };
  document.querySelectorAll('.agent-action').forEach(button => {
    button.addEventListener('click', async () => {
      const endpoint = button.dataset.endpoint || '/api/agent/run';
      const scenario = button.dataset.scenario;
      const original = button.textContent;
      button.disabled = true; button.textContent = 'Running...'; state.textContent = 'Loading'; state.className = 'badge bg-warning';
      try {
        const response = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ scenario }) });
        const data = await response.json();
        if (!response.ok) throw new Error(data.message || 'Agent request failed');
        render(data); state.textContent = 'Complete'; state.className = 'badge bg-success';
      } catch (error) {
        output.className = 'alert alert-danger'; output.textContent = error.message; state.textContent = 'Failed'; state.className = 'badge bg-danger';
        audit.insertAdjacentHTML('afterbegin', `<li>${new Date().toLocaleTimeString()} action failed: ${escapeHtml(error.message)}</li>`);
      } finally { button.disabled = false; button.textContent = original; }
    });
  });
})();
</script>
