@{
    ViewData["Title"] = "CivicOps AI Agent Command Centre";
}

<div class="container-fluid py-4 civic-page agent-command" data-gemini-mode="@ViewBag.GeminiMode" data-whatsapp-mode="@ViewBag.WhatsAppMode">
    <div class="hero-panel mb-4">
        <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 align-items-xl-end">
            <div>
                <span class="eyebrow">Pilot connector-ready operations agent</span>
                <h1 class="display-6 fw-bold mb-2">CivicOps AI Agent Command Centre</h1>
                <p class="lead mb-0">Live connector-ready civic operations agent for report validation, routing, escalation, citizen response, and audit.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" href="/Home/DemoTour"><i class="bi bi-map me-1"></i>Judge Tour</a>
                <a class="btn btn-outline-info" href="/Home/Connectors"><i class="bi bi-plug me-1"></i>Connector Readiness</a>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4" id="statusCards">
        <div class="col-sm-6 col-xl"><div class="metric-card"><div class="metric-label">Agent status</div><div class="metric-value text-success">Operational</div><small>Human-in-the-loop workflow online</small></div></div>
        <div class="col-sm-6 col-xl"><div class="metric-card"><div class="metric-label">Gemini status</div><div class="metric-value" id="geminiStatus">Loading</div><small id="geminiNote">Checking connector readiness…</small></div></div>
        <div class="col-sm-6 col-xl"><div class="metric-card"><div class="metric-label">WhatsApp status</div><div class="metric-value" id="whatsappStatus">Loading</div><small id="whatsappNote">Checking Cloud API readiness…</small></div></div>
        <div class="col-sm-6 col-xl"><div class="metric-card"><div class="metric-label">Intake pipeline</div><div class="metric-value text-info">Unified</div><small>IncidentIntakeService shared by web, API, WhatsApp, voice, and agent flows</small></div></div>
        <div class="col-sm-6 col-xl"><div class="metric-card"><div class="metric-label">Last action</div><div class="metric-value fs-6" id="lastAction">Not run yet</div><small>UTC timestamp updates after each backend call</small></div></div>
    </div>

    <div class="alert alert-info border-0 shadow-sm">
        <strong>Honest mode:</strong> This page uses synthetic civic operations scenarios for judging. It creates real CivicOps incident records through the shared intake pipeline. Live Gemini and WhatsApp behavior only appears when the required environment variables are configured.
    </div>

    <div class="row g-4">
        <aside class="col-lg-3">
            <div class="ops-card h-100">
                <div class="card-kicker">1 · Scenario/input selector</div>
                <h2 class="h5">Run an agent action</h2>
                <p class="text-muted-strong">Every button calls the backend with <code>fetch()</code>; no dead static controls.</p>
                <div class="d-grid gap-2" id="scenarioButtons">
                    <button class="btn btn-primary agent-action" data-scenario="latest-report">Analyze latest resident report</button>
                    <button class="btn btn-primary agent-action" data-scenario="whatsapp-report">Analyze WhatsApp report</button>
                    <button class="btn btn-primary agent-action" data-scenario="voice-note">Analyze voice-note transcript</button>
                    <button class="btn btn-outline-info agent-action" data-scenario="gemini-health">Run live Gemini health test</button>
                    <button class="btn btn-outline-light agent-action" data-scenario="citizen-response" data-endpoint="/api/agent/generate-response">Generate citizen response</button>
                    <button class="btn btn-outline-light agent-action" data-scenario="department-brief">Generate department brief</button>
                    <button class="btn btn-outline-warning agent-action" data-scenario="area-alert" data-endpoint="/api/agent/recommend-alert">Recommend area alert</button>
                    <button class="btn btn-success agent-action" data-scenario="judge-summary">Generate judge summary</button>
                </div>

                <hr class="border-secondary my-4" />
                <label class="form-label" for="customInput">Optional custom report text</label>
                <textarea id="customInput" class="form-control" rows="6" placeholder="Override the selected scenario with a custom resident message..."></textarea>
                <div class="row g-2 mt-2">
                    <div class="col-6"><input class="form-control" id="customSuburb" placeholder="Suburb" /></div>
                    <div class="col-6"><input class="form-control" id="customWard" placeholder="Ward" /></div>
                </div>
            </div>
        </aside>

        <main class="col-lg-6">
            <div class="ops-card h-100">
                <div class="card-kicker">2 · Agent workflow output</div>
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h2 class="h4 mb-1" id="workflowTitle">Awaiting first action</h2>
                        <p class="text-muted-strong mb-0" id="workflowSubtitle">Select a scenario to validate, classify, route, acknowledge, and audit through the backend.</p>
                    </div>
                    <span class="status-pill status-info" id="aiSource">Ready</span>
                </div>
                <div id="loadingState" class="loading-panel my-4 d-none">
                    <div class="spinner-border text-info" role="status" aria-hidden="true"></div>
                    <span>Calling CivicOps backend pipeline…</span>
                </div>
                <div class="workflow-grid mt-4" id="workflowGrid">
                    <div class="workflow-node"><span>1</span><strong>Signal intake</strong><small>Web / WhatsApp / voice / mobile</small></div>
                    <div class="workflow-node"><span>2</span><strong>Validation</strong><small>Spam, sufficiency, emergency guidance</small></div>
                    <div class="workflow-node"><span>3</span><strong>Classification</strong><small>Gemini if enabled; fallback otherwise</small></div>
                    <div class="workflow-node"><span>4</span><strong>Routing</strong><small>Department, priority, reason</small></div>
                    <div class="workflow-node"><span>5</span><strong>Response</strong><small>Reference and citizen wording</small></div>
                    <div class="workflow-node"><span>6</span><strong>Audit</strong><small>Traceable notes and human review</small></div>
                </div>
                <div class="result-panel mt-4" id="workflowResult">
                    <p class="mb-0 text-muted-strong">Results appear here after the backend response.</p>
                </div>
            </div>
        </main>

        <aside class="col-lg-3">
            <div class="ops-card h-100">
                <div class="card-kicker">3 · Ticket/action result and audit</div>
                <h2 class="h5">Operational result</h2>
                <dl class="result-list mb-3">
                    <dt>Reference</dt><dd id="ticketReference">—</dd>
                    <dt>Department</dt><dd id="ticketDepartment">—</dd>
                    <dt>Priority</dt><dd id="ticketPriority">—</dd>
                    <dt>Validation</dt><dd id="ticketValidation">—</dd>
                    <dt>WhatsApp</dt><dd id="ticketWhatsapp">—</dd>
                </dl>
                <a class="btn btn-outline-info w-100 disabled" id="incidentLink" href="#">Open incident detail</a>
                <hr class="border-secondary my-4" />
                <h3 class="h6">Audit trail</h3>
                <ul class="audit-list" id="auditTrail">
                    <li>Agent console loaded.</li>
                    <li>Awaiting backend scenario execution.</li>
                </ul>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const $ = (id) => document.getElementById(id);
    const buttons = document.querySelectorAll('.agent-action');

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
    }

    function setBusy(isBusy) {
        $('loadingState').classList.toggle('d-none', !isBusy);
        buttons.forEach(button => button.disabled = isBusy);
    }

    function setStatusFromScenarios(payload) {
        const gemini = payload.gemini || {};
        const whatsapp = payload.whatsapp || {};
        $('geminiStatus').textContent = gemini.enabled ? 'Live Ready' : 'Fallback Active';
        $('geminiNote').textContent = gemini.enabled ? `${gemini.model} · ${gemini.mode}` : 'Fallback active — configure GEMINI_API_KEY and GEMINI_ENABLED=true for live Gemini.';
        $('whatsappStatus').textContent = whatsapp.canSend ? 'Live Ready' : (whatsapp.verifyTokenPresent ? 'Webhook Ready' : 'Sandbox Active');
        $('whatsappNote').textContent = whatsapp.status || 'Sandbox WhatsApp flow active — Cloud API activates through env vars.';
    }

    async function loadScenarios() {
        try {
            const response = await fetch('/api/agent/scenarios');
            const payload = await response.json();
            if (payload.success) setStatusFromScenarios(payload);
        } catch (error) {
            $('geminiStatus').textContent = 'Status unavailable';
            $('whatsappStatus').textContent = 'Status unavailable';
            console.error('Unable to load agent scenarios', error);
        }
    }

    function renderResult(result) {
        $('lastAction').textContent = new Date(result.timestamp || Date.now()).toLocaleString();
        $('workflowTitle').textContent = result.action || 'Agent action completed';
        $('workflowSubtitle').textContent = `${result.sourceChannel || 'Unknown'} · ${result.aiSource || 'Fallback'}`;
        $('aiSource').textContent = result.aiSource || 'Fallback active';
        $('aiSource').className = `status-pill ${result.geminiAssisted ? 'status-success' : 'status-warning'}`;

        $('workflowResult').innerHTML = `
            <div class="row g-3">
                <div class="col-md-6"><strong>Source channel</strong><p>${escapeHtml(result.sourceChannel)}</p></div>
                <div class="col-md-6"><strong>AI source</strong><p>${escapeHtml(result.aiSource)}</p></div>
                <div class="col-md-6"><strong>Department / authority</strong><p>${escapeHtml(result.department)}</p></div>
                <div class="col-md-6"><strong>Priority</strong><p>${escapeHtml(result.priority)}</p></div>
                <div class="col-12"><strong>Routing reason</strong><p>${escapeHtml(result.routingReason)}</p></div>
                <div class="col-12"><strong>Citizen response</strong><p>${escapeHtml(result.citizenResponse)}</p></div>
                <div class="col-12"><strong>Alert recommendation</strong><p>${escapeHtml(result.alertRecommendation)}</p></div>
            </div>`;

        $('ticketReference').textContent = result.referenceNumber || 'Connector check only';
        $('ticketDepartment').textContent = result.department || '—';
        $('ticketPriority').textContent = result.priority || '—';
        $('ticketValidation').textContent = result.validation || '—';
        $('ticketWhatsapp').textContent = result.whatsapp?.status || 'Sandbox flow status unavailable';

        if (result.incidentUrl) {
            $('incidentLink').href = result.incidentUrl;
            $('incidentLink').classList.remove('disabled');
        } else {
            $('incidentLink').href = '#';
            $('incidentLink').classList.add('disabled');
        }

        const notes = Array.isArray(result.auditNotes) ? result.auditNotes : [];
        $('auditTrail').innerHTML = notes.map(note => `<li>${escapeHtml(note)}</li>`).join('') || '<li>No audit notes returned.</li>';
    }

    async function runScenario(button) {
        const scenario = button.dataset.scenario;
        const endpoint = button.dataset.endpoint || '/api/agent/run';
        const body = {
            scenario,
            input: $('customInput').value,
            suburb: $('customSuburb').value,
            ward: $('customWard').value
        };

        setBusy(true);
        try {
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const result = await response.json();
            if (!response.ok || !result.success) throw new Error(result.message || 'Agent action failed');
            renderResult(result);
        } catch (error) {
            $('workflowResult').innerHTML = `<div class="alert alert-danger"><strong>Agent request failed:</strong> ${escapeHtml(error.message)}</div>`;
            $('auditTrail').innerHTML = `<li>Request failed: ${escapeHtml(error.message)}</li>`;
        } finally {
            setBusy(false);
        }
    }

    buttons.forEach(button => button.addEventListener('click', () => runScenario(button)));
    loadScenarios();
})();
</script>
}
