@{
    ViewData["Title"] = "CivicOps Mobile & WhatsApp Access";
}

<div class="container py-4 civic-page mobile-hub">
    <div class="hero-panel mb-4">
        <span class="eyebrow">Public utility access hub</span>
        <h1 class="display-6 fw-bold">CivicOps Mobile & WhatsApp Access</h1>
        <p class="lead mb-0">A mobile-first reporting path for residents, field teams, and WhatsApp-first communities.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4"><div class="ops-card h-100"><span class="status-pill status-success">PWA Ready</span><h2 class="h4">Web/PWA app</h2><ul class="feature-list"><li>Report issue</li><li>Track reference</li><li>View alerts</li><li>Follow area</li></ul><a class="btn btn-primary" href="/Home/Report">Report issue</a></div></div>
        <div class="col-lg-4"><div class="ops-card h-100"><span class="status-pill status-info">Android-ready</span><h2 class="h4">Android-ready app/source</h2><ul class="feature-list"><li>Report</li><li>Track</li><li>Alerts</li><li>Responder mode future</li></ul><a class="btn btn-outline-info" href="/docs/android-app.md">Android notes</a></div></div>
        <div class="col-lg-4"><div class="ops-card h-100"><span class="status-pill status-warning">Sandbox / Live ready</span><h2 class="h4">WhatsApp-first reporting</h2><ul class="feature-list"><li>Report without installing app</li><li>Receive reference</li><li>Track status</li><li>Cloud API activates with Meta env vars</li></ul><a class="btn btn-success" href="/Demo/WhatsAppSimulator">Open WhatsApp Intake</a></div></div>
    </div>

    <div class="phone-shell mx-auto">
        <div class="phone-status">CivicOps <span>09:41</span></div>
        <div class="app-grid">
            <a href="/Home/Report" class="app-tile"><i class="bi bi-plus-circle"></i><strong>Report Issue</strong><small>Photo/location ready</small></a>
            <a href="/Home/Lookup" class="app-tile"><i class="bi bi-search"></i><strong>My References</strong><small>Track CIV-2026-0001</small></a>
            <a href="/Home/Alerts" class="app-tile"><i class="bi bi-bell"></i><strong>Area Alerts</strong><small>Ward and suburb notices</small></a>
            <a href="/Home/Weather" class="app-tile"><i class="bi bi-cloud-rain-heavy"></i><strong>Weather Risk</strong><small>Context for operations</small></a>
            <a href="/Demo/WhatsAppSimulator" class="app-tile whatsapp"><i class="bi bi-whatsapp"></i><strong>WhatsApp Shortcut</strong><small>No install required</small></a>
            <div class="app-tile emergency"><i class="bi bi-exclamation-triangle"></i><strong>Emergency disclaimer</strong><small>CivicOps is not an emergency services replacement.</small></div>
        </div>
    </div>
</div>
