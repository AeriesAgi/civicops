@{
    ViewData["Title"] = "Mobile & PWA";
}

<div class="container">
    <h1 style="color: #06b6d4; margin-bottom: 2rem;">📱 Mobile & PWA Readiness</h1>

    <div class="card" style="margin-bottom: 2rem;">
        <h2 class="card-title">CivicOps Mobile Access</h2>
        <p style="color: #cbd5e1; line-height: 1.8;">
            CivicOps is designed for mobile-first civic reporting. Access the platform through multiple channels:
        </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        <div class="card">
            <h3 style="color: #06b6d4; margin-bottom: 1rem;">🌐 Progressive Web App (PWA)</h3>
            <p style="color: #cbd5e1; line-height: 1.8; margin-bottom: 1rem;">
                Access CivicOps directly from your mobile browser. The web interface is fully responsive and mobile-optimized.
            </p>
            <ul style="color: #94a3b8; line-height: 1.8;">
                <li>No installation required</li>
                <li>Works on any device</li>
                <li>Mobile-optimized forms</li>
                <li>Quick report submission</li>
                <li>Status tracking</li>
            </ul>
            <a href="/Home/Report" class="btn btn-primary" style="margin-top: 1rem; width: 100%;">
                Report via Web
            </a>
        </div>

        <div class="card">
            <h3 style="color: #06b6d4; margin-bottom: 1rem;">📱 Android App</h3>
            <p style="color: #cbd5e1; line-height: 1.8; margin-bottom: 1rem;">
                Native Android app for enhanced mobile experience with offline support and push notifications.
            </p>
            <ul style="color: #94a3b8; line-height: 1.8;">
                <li>Native mobile experience</li>
                <li>Camera integration</li>
                <li>Location services</li>
                <li>Push notifications (future)</li>
                <li>Offline draft support (future)</li>
            </ul>
            <div style="margin-top: 1rem; padding: 1rem; background: rgba(251, 191, 36, 0.1); border-radius: 0.5rem; border: 1px solid rgba(251, 191, 36, 0.3);">
                <p style="color: #fbbf24; font-size: 0.875rem; margin: 0;">
                    <strong>Development Build:</strong> Android app source available in /mobile/CivicOpsAndroid. Build with Android Studio.
                </p>
            </div>
        </div>

        <div class="card">
            <h3 style="color: #06b6d4; margin-bottom: 1rem;">💬 WhatsApp Reporting</h3>
            <p style="color: #cbd5e1; line-height: 1.8; margin-bottom: 1rem;">
                Report issues directly via WhatsApp text messages. Simple and accessible for all residents.
            </p>
            <ul style="color: #94a3b8; line-height: 1.8;">
                <li>Text-based reporting</li>
                <li>No app installation needed</li>
                <li>Works on any phone</li>
                <li>Automatic classification</li>
                <li>Reference number via reply</li>
            </ul>
            <a href="/demo/whatsapp" class="btn btn-secondary" style="margin-top: 1rem; width: 100%;">
                Try WhatsApp Demo
            </a>
        </div>

        <div class="card">
            <h3 style="color: #06b6d4; margin-bottom: 1rem;">🎤 Voice Note Reporting</h3>
            <p style="color: #cbd5e1; line-height: 1.8; margin-bottom: 1rem;">
                Submit reports using voice notes for quick, hands-free reporting while on the go.
            </p>
            <ul style="color: #94a3b8; line-height: 1.8;">
                <li>Voice-to-text transcription</li>
                <li>Hands-free reporting</li>
                <li>Quick submission</li>
                <li>Automatic processing</li>
                <li>Multi-language support (future)</li>
            </ul>
            <a href="/demo/voicenote" class="btn btn-secondary" style="margin-top: 1rem; width: 100%;">
                Try Voice Note Demo
            </a>
        </div>
    </div>

    <div class="card" style="margin-top: 2rem;">
        <h2 class="card-title">Mobile Features</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <h4 style="color: #06b6d4; margin-bottom: 0.5rem;">📝 Quick Reporting</h4>
                <p style="color: #94a3b8; font-size: 0.875rem;">Submit civic issues in seconds from your mobile device</p>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <h4 style="color: #06b6d4; margin-bottom: 0.5rem;">📍 Location Services</h4>
                <p style="color: #94a3b8; font-size: 0.875rem;">Automatic location detection for accurate incident reporting</p>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <h4 style="color: #06b6d4; margin-bottom: 0.5rem;">📷 Photo Upload</h4>
                <p style="color: #94a3b8; font-size: 0.875rem;">Capture and attach photos directly from your camera</p>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <h4 style="color: #06b6d4; margin-bottom: 0.5rem;">🔍 Status Tracking</h4>
                <p style="color: #94a3b8; font-size: 0.875rem;">Track your reports and receive updates on the go</p>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <h4 style="color: #06b6d4; margin-bottom: 0.5rem;">📢 Area Alerts</h4>
                <p style="color: #94a3b8; font-size: 0.875rem;">Receive location-based alerts for your area</p>
            </div>
            <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                <h4 style="color: #06b6d4; margin-bottom: 0.5rem;">🔔 Notifications</h4>
                <p style="color: #94a3b8; font-size: 0.875rem;">Push notifications for status updates (future)</p>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top: 2rem; background: rgba(6, 182, 212, 0.1); border-color: rgba(6, 182, 212, 0.3);">
        <h3 style="color: #06b6d4; margin-bottom: 1rem;">For Responders</h3>
        <p style="color: #cbd5e1; line-height: 1.8;">
            Municipal department staff can access CivicOps on mobile devices to:
        </p>
        <ul style="color: #cbd5e1; line-height: 1.8;">
            <li>View department incident queues</li>
            <li>Update incident status in the field</li>
            <li>Add notes and photos from site visits</li>
            <li>Escalate urgent issues</li>
            <li>Coordinate with other departments</li>
        </ul>
    </div>
</div>
