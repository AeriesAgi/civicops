@{
    var appShell = ViewBag.AppShell == true;
    ViewData["Title"] = appShell ? "CivicOps Citizen App" : "Citizen App Download / Install Hub";
    var pwaReady = ViewBag.PwaReady == true;
    var apkExists = ViewBag.ApkExists == true;
    var appAuthenticated = ViewBag.AppAuthenticated == true;
    var appSignupMode = ViewBag.AppSignupMode == true;
    var appResidentName = ViewBag.AppResidentName as string ?? "Demo Resident";
    var appMessage = ViewBag.AppMessage as string;
    var appStartSection = ViewBag.AppStartSection as string;
}
@if (appShell && !appAuthenticated)
{
<div class="citizen-app-shell app-login-shell" data-app-shell="true">
    <main class="app-login-screen">
        <div class="app-login-brand"><span class="brand-mark"><i class="bi bi-command"></i></span><span class="eyebrow">CivicOps Citizen</span></div>
        <section class="app-login-card">
            <span class="badge bg-info">Demo-safe app access</span>
            <h1>@(appSignupMode ? "Create a demo citizen profile" : "Open the Citizen App")</h1>
            <p>CivicOps Citizen is app-first: report issues, track tickets, follow areas, confirm impact and use Copilot without entering the public website shell.</p>
            @if (!string.IsNullOrWhiteSpace(appMessage)) { <div class="alert alert-success">@appMessage</div> }
            @if (appSignupMode)
            {
                <form method="post" action="/app/create-demo-profile" class="app-form mt-3">
                    <input class="form-control mb-2" name="displayName" placeholder="Display name" value="Demo Resident" />
                    <input class="form-control mb-3" name="area" placeholder="Area to follow" value="Chatsworth" />
                    <button class="btn btn-primary w-100" type="submit">Create demo profile</button>
                </form>
            }
            else
            {
                <form method="post" action="/app/demo-resident" class="d-grid gap-2 mt-3"><button class="btn btn-primary btn-lg" type="submit"><i class="bi bi-phone me-2"></i>Continue as demo resident</button></form>
                <a class="btn btn-outline-info w-100 mt-2" href="/app/signup">Create demo profile</a>
                <div class="app-login-track mt-3"><label class="form-label small">Track existing reference inside the app</label><div class="input-group"><input id="loginTrackRef" class="form-control" placeholder="CIV-2026-0001"><button id="loginTrackBtn" class="btn btn-outline-light" type="button">Track</button></div><div id="loginTrackResult" class="app-result"></div></div>
            }
            <div class="app-login-demo-grid mt-4"><a href="/app/login"><strong>Resident app only</strong><small>No public website shell</small></a><a href="/app/signup"><strong>Create profile</strong><small>Demo-safe app access</small></a></div>
            <p class="small text-muted-strong mt-3 mb-0">Hackathon demo access only. CivicOps does not replace emergency services.</p>
        </section>
    </main>
</div>
<script>
(() => {
  const button = document.getElementById('loginTrackBtn');
  if (!button) return;
  button.addEventListener('click', async () => {
    const ref = document.getElementById('loginTrackRef').value.trim();
    if (!ref) return;
    const r = await fetch('/api/reports/' + encodeURIComponent(ref));
    const data = await r.json();
    document.getElementById('loginTrackResult').innerHTML = data.success
      ? `<div class="alert alert-info mt-2"><strong>${data.referenceNumber}</strong><br>${data.status} · ${data.department}<br>${data.latestUpdate?.content || 'Public update pending.'}</div>`
      : '<div class="alert alert-warning mt-2">Reference not found.</div>';
  });
})();
</script>
}
else if (appShell)
{
<div class="citizen-app-shell" data-app-shell="true" data-start-section="@appStartSection">
    <header class="app-topbar">
        <div><span class="eyebrow">CivicOps Citizen</span><h1>Good morning, @appResidentName</h1></div>
        <form method="post" action="/app/logout" class="m-0"><button class="app-icon-btn" type="submit" aria-label="Switch demo role"><i class="bi bi-arrow-repeat"></i></button></form>
    </header>
    <main class="app-scroll">
        <section class="app-hero-card">
            <div><span class="badge bg-success">Live civic companion</span><h2>CivicOps AI turns scattered civic reports into structured municipal action.</h2><p>Report, track, follow areas, confirm impact and ask Copilot from a standalone app-first shell.</p></div>
            <div class="app-radar"><span></span><span></span><span></span></div>
        </section>
        <section class="app-grid-metrics" id="appMetrics">
            <div><strong>--</strong><span>Active near you</span></div><div><strong>--</strong><span>Open tickets</span></div><div><strong>--</strong><span>Alerts</span></div><div><strong>--</strong><span>Affected confirmations</span></div>
        </section>
        <section class="app-panel" id="home"><div class="d-flex justify-content-between align-items-center"><h2>Citizen Home</h2><form method="post" action="/app/logout"><button class="btn btn-sm btn-outline-info" type="submit">Switch demo role</button></form></div><p class="small mb-2">Followed areas: <span id="followedAreas">Chatsworth · Phoenix · Umlazi</span></p><div id="nearbyTickets" class="app-list"></div></section>
        <section class="app-panel" id="report"><h2>Report Issue</h2><form id="citizenReportForm" class="app-form"><textarea name="description" class="form-control" rows="4" placeholder="Example: There is a burst pipe outside Main Road in Chatsworth near the school, water is flooding the street and traffic is affected." required></textarea><div class="row g-2 mt-2"><div class="col-6"><input name="suburb" class="form-control" placeholder="Optional suburb / area"></div><div class="col-6"><input name="ward" class="form-control" placeholder="Optional ward"></div></div><input name="locationNotes" class="form-control mt-2" placeholder="Optional landmark / street"><button class="btn btn-primary w-100 mt-3" type="submit"><i class="bi bi-send me-1"></i>Submit civic report</button></form><div id="reportResult" class="app-result"></div></section>
        <section class="app-panel" id="tickets"><h2>My Tickets / Track Reference</h2><div class="input-group mb-3"><input id="trackRef" class="form-control" placeholder="CIV-2026-0001"><button class="btn btn-outline-info" id="trackBtn">Track</button></div><div id="ticketList" class="app-list"></div></section>
        <section class="app-panel" id="alerts"><h2>Area Alerts</h2><div class="d-flex gap-2 mb-3"><input id="followArea" class="form-control" value="Chatsworth"><button class="btn btn-outline-info" id="followBtn">Follow area</button></div><div id="alertList" class="app-list"></div></section>
        <section class="app-panel" id="copilot"><h2>CivicOps Copilot Report Intake</h2><p class="small">CivicOps Copilot helps you turn a messy civic issue into a structured municipal report. Gemini is only used server-side when explicitly submitted/configured; this guided flow has a deterministic fallback.</p><div id="copilotChat" class="copilot-chat"><div class="copilot-bubble bot">What happened? Describe the civic issue in your own words.</div></div><textarea id="copilotStepInput" class="form-control mt-2" rows="3" placeholder="Type your answer..."></textarea><div class="d-grid gap-2 mt-2"><button class="btn btn-primary" id="copilotNext" type="button">Next step</button><button class="btn btn-outline-info d-none" id="copilotSubmitReport" type="button">Submit structured report</button></div><div id="copilotPreview" class="app-result"></div><hr/><h3 class="h6">Ask about an existing ticket</h3><input id="copilotRef" class="form-control mb-2" placeholder="Optional reference number"><textarea id="copilotQuestion" class="form-control" rows="2" placeholder="Ask what happens next or how to track a report."></textarea><button class="btn btn-outline-info w-100 mt-2" id="askCopilot" type="button">Ask ticket Copilot</button><div id="copilotAnswer" class="app-result"></div></section>
        <section class="app-panel" id="profile"><h2>Profile / Settings</h2><div class="app-profile"><strong>Resident demo profile</strong><p>Selected municipality: eThekwini · Notifications: area alerts + ticket updates · Channels: app/PWA/APK.</p><form method="post" action="/app/logout"><button class="btn btn-outline-info btn-sm" type="submit">Switch demo profile</button></form></div><div class="alert alert-warning mt-3 small">CivicOps does not replace police, fire, EMS, or emergency services. Immediate danger must be reported directly to emergency services.</div></section>
    </main>
    <nav class="app-bottom-nav"><a href="#home"><i class="bi bi-house"></i><span>Home</span></a><a href="#report"><i class="bi bi-plus-circle"></i><span>Report</span></a><a href="#tickets"><i class="bi bi-ticket"></i><span>Tickets</span></a><a href="#alerts"><i class="bi bi-bell"></i><span>Alerts</span></a><a href="#copilot"><i class="bi bi-stars"></i><span>Copilot</span></a><a href="#profile"><i class="bi bi-person"></i><span>Profile</span></a></nav>
</div>
<script>
(() => {
  const state = { tickets: [], alerts: [], area: 'Chatsworth' };
  const ticketCard = t => `<article class="app-ticket"><div><strong>${t.referenceNumber}</strong><p>${t.area} · ${t.department}</p><small>${t.latestUpdate || 'Public update pending.'}</small></div><div class="text-end"><span class="badge bg-info">${t.status}</span><span class="badge bg-warning d-block mt-1">${t.priority}</span><button class="btn btn-sm btn-outline-info mt-2 affected" data-ref="${t.referenceNumber}">I'm affected too (${t.affectedCount || 0})</button></div></article>`;
  const loadHome = async () => { const r = await fetch('/api/mobile/citizen/home?area=' + encodeURIComponent(state.area)); const data = await r.json(); state.tickets = data.tickets || []; state.alerts = data.alerts || []; document.querySelector('#appMetrics').innerHTML = `<div><strong>${data.stats.activeNearYou}</strong><span>Active near you</span></div><div><strong>${data.stats.openTickets}</strong><span>Open tickets</span></div><div><strong>${data.stats.alerts}</strong><span>Alerts</span></div><div><strong>${data.stats.affectedConfirmations}</strong><span>Affected confirmations</span></div>`; document.querySelector('#nearbyTickets').innerHTML = (data.nearby || data.tickets).map(ticketCard).join(''); document.querySelector('#ticketList').innerHTML = data.tickets.map(ticketCard).join(''); document.querySelector('#alertList').innerHTML = data.alerts.map(a => `<article class="app-ticket"><div><strong>${a.title}</strong><p>${a.suburb} · ${a.ward}</p><small>${a.description}</small></div><span class="badge bg-warning">${a.severity}</span></article>`).join('') || '<p>No active alerts for this followed area.</p>'; };
  document.addEventListener('click', async e => { if (e.target.matches('.affected')) { const ref = e.target.dataset.ref; const r = await fetch('/api/mobile/citizen/affected', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ referenceNumber: ref, area: state.area }) }); const data = await r.json(); e.target.textContent = `I'm affected too (${data.affectedCount})`; await loadHome(); } });
  document.querySelector('#citizenReportForm').addEventListener('submit', async e => { e.preventDefault(); const f = new FormData(e.target); const payload = Object.fromEntries(f.entries()); const r = await fetch('/api/mobile/citizen/report', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) }); const data = await r.json(); document.querySelector('#reportResult').innerHTML = `<div class="alert alert-success mt-3"><strong>${data.referenceNumber}</strong><br>${data.citizenResponse || data.message}<br><span class="badge bg-info">${data.department}</span> <span class="badge bg-warning">${data.priority}</span></div>`; document.querySelector('#trackRef').value = data.referenceNumber; await loadHome(); });
  document.querySelector('#trackBtn').addEventListener('click', async () => { const ref = document.querySelector('#trackRef').value.trim(); if (!ref) return; const r = await fetch('/api/reports/' + encodeURIComponent(ref)); const data = await r.json(); document.querySelector('#ticketList').innerHTML = data.success ? ticketCard({ referenceNumber:data.referenceNumber, area:data.normalizedArea, department:data.department, latestUpdate:data.latestUpdate?.content, status:data.status, priority:data.priority, affectedCount:0 }) : '<div class="alert alert-warning">Reference not found.</div>'; });
  document.querySelector('#followBtn').addEventListener('click', async () => { state.area = document.querySelector('#followArea').value || 'Chatsworth'; document.querySelector('#followedAreas').textContent = `${state.area} · Chatsworth · Phoenix · Umlazi`; await loadHome(); });
  document.querySelector('#askCopilot').addEventListener('click', async () => { const r = await fetch('/api/mobile/copilot/citizen', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ referenceNumber: document.querySelector('#copilotRef').value, question: document.querySelector('#copilotQuestion').value, area: state.area }) }); const data = await r.json(); document.querySelector('#copilotAnswer').innerHTML = `<div class="alert alert-info mt-3">${data.answer}<br><small>${data.gemini}</small></div>`; });
  const intake = { step: 0, description: '', area: '', contact: '', danger: '' };
  const prompts = ['Where is this happening? Include suburb, ward, street or landmark.', 'What name or contact/display name should staff see?', 'Is anyone in immediate danger? Type yes or no.'];
  const normalizeArea = value => {
    const text = (value || '').trim();
    const key = text.toLowerCase();
    if (key.includes('chatworth')) return 'Chatsworth';
    if (key.includes('pheonix') || key.includes('phoenix')) return 'Phoenix';
    if (key.includes('durbn') || key.includes('dbn town') || key.includes('durban cbd')) return 'Durban CBD';
    if (key.includes('umlaz')) return 'Umlazi';
    if (key.includes('kwa mashu') || key.includes('kwamashu')) return 'KwaMashu';
    if (key.includes('pinetowm') || key.includes('pinetown')) return 'Pinetown';
    if (key.includes('amanzi mtoti') || key.includes('amanzimtoti')) return 'Amanzimtoti';
    if (key.includes('ethekweni') || key.includes('ethekwini')) return 'eThekwini';
    return text || 'Area to confirm';
  };
  const classify = text => {
    const value = (text || '').toLowerCase();
    if (value.includes('water') || value.includes('pipe') || value.includes('leak')) return ['Water disruption', 'Water & Sanitation', 'High'];
    if (value.includes('electric') || value.includes('streetlight') || value.includes('cable') || value.includes('power')) return ['Electricity fault', 'Electricity & Power', value.includes('danger') || value.includes('sparking') ? 'Critical' : 'High'];
    if (value.includes('road') || value.includes('pothole') || value.includes('drain')) return ['Roads / stormwater', 'Roads & Infrastructure', 'Medium'];
    if (value.includes('waste') || value.includes('refuse')) return ['Waste disruption', 'Waste Management', 'Medium'];
    return ['Civic service issue', 'Community Liaison', 'Medium'];
  };
  const addBubble = (who, text) => document.querySelector('#copilotChat').insertAdjacentHTML('beforeend', `<div class="copilot-bubble ${who}">${text}</div>`);
  document.querySelector('#copilotNext').addEventListener('click', () => {
    const input = document.querySelector('#copilotStepInput');
    const answer = input.value.trim(); if (!answer) return;
    addBubble('user', answer);
    if (intake.step === 0) intake.description = answer;
    if (intake.step === 1) intake.area = answer;
    if (intake.step === 2) intake.contact = answer;
    if (intake.step === 3) intake.danger = answer;
    input.value = '';
    if (intake.step < prompts.length) { addBubble('bot', prompts[intake.step]); intake.step += 1; return; }
    const normalized = normalizeArea(intake.area);
    const [category, department, priority] = classify(`${intake.description} ${intake.danger}`);
    intake.normalizedArea = normalized; intake.category = category; intake.department = department; intake.priority = priority;
    const emergency = /yes|danger|fire|sparking|injur/i.test(intake.danger);
    document.querySelector('#copilotPreview').innerHTML = `<div class="alert alert-info mt-3"><strong>Structured report preview</strong><br>Issue: ${category}<br>Area: ${normalized}<br>Department: ${department}<br>Priority: ${priority}<br>Contact: ${intake.contact}<br>${emergency ? '<strong>Emergency reminder:</strong> contact emergency services directly if anyone is in immediate danger.<br>' : ''}<span class="badge bg-secondary">Deterministic fallback ready</span></div>`;
    addBubble('bot', 'Preview ready. Submit this report?');
    document.querySelector('#copilotSubmitReport').classList.remove('d-none');
  });
  document.querySelector('#copilotSubmitReport').addEventListener('click', async () => {
    const payload = { description: intake.description, suburb: intake.normalizedArea, contactName: intake.contact, locationNotes: `Copilot guided intake. Immediate danger answer: ${intake.danger}`, category: intake.category };
    const r = await fetch('/api/mobile/citizen/report', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
    const data = await r.json();
    addBubble('bot', `Submitted. Your reference is <strong>${data.referenceNumber}</strong>.`);
    document.querySelector('#copilotPreview').innerHTML += `<div class="alert alert-success mt-2"><strong>${data.referenceNumber}</strong> created. Use the Tickets tab to track status.</div>`;
    await loadHome();
  });
  const startSection = document.querySelector('.citizen-app-shell').dataset.startSection;
  if (startSection) setTimeout(() => document.querySelector('#' + startSection)?.scrollIntoView({behavior:'smooth'}), 300);
  loadHome();
})();
</script>
}
else
{
<div class="container py-4 civic-page">
    <section class="hero-panel mb-4"><span class="eyebrow">Download App / Install Hub</span><h1 class="display-5">Install the CivicOps Citizen App</h1><p class="lead">Open the standalone /app shell or install the Android APK. The APK target is <code>https://civicops.culltron.app/app</code> and contains no API keys.</p><div class="d-flex gap-2 flex-wrap"><span class="badge bg-success">@(pwaReady ? "PWA ready" : "PWA shell available")</span><span class="badge bg-info">Android workflow preserved</span><span class="badge bg-info">Starts at /app</span><span class="badge bg-secondary">APK @(apkExists ? "available" : "artifact pending")</span></div><div class="command-strip mt-4"><a class="btn btn-primary btn-lg" href="/app">Open Citizen App</a><a class="btn btn-outline-info btn-lg" href="/Home/Report">Report Issue</a><a class="btn btn-outline-light btn-lg" href="/Home/Lookup">Track Reference</a>@if (apkExists) { <a class="btn btn-outline-warning btn-lg" href="/downloads/CivicOpsCitizenCompanion-debug.apk">Download Android APK</a> } else { <span class="btn btn-outline-warning btn-lg disabled">APK artifact pending</span> }</div></section>
    <div class="row g-4"><div class="col-lg-4"><div class="ops-card h-100"><span class="eyebrow">Option 1</span><h2 class="h4">Open Citizen App</h2><p>The /app route hides the public website shell and presents Citizen Home, Report Issue, Tickets, Alerts, Copilot and Profile.</p><a class="btn btn-primary" href="/app">Open /app</a></div></div><div class="col-lg-4"><div class="ops-card h-100"><span class="eyebrow">Option 2</span><h2 class="h4">Download APK</h2>@if (apkExists) { <p>The APK is served from <code>/downloads/CivicOpsCitizenCompanion-debug.apk</code>.</p><a class="btn btn-primary" href="/downloads/CivicOpsCitizenCompanion-debug.apk">Download APK</a> } else { <p>APK artifact pending. GitHub Actions builds and copies it to <code>wwwroot/downloads</code>.</p> }</div></div><div class="col-lg-4"><div class="ops-card h-100"><span class="eyebrow">Demo access</span><h2 class="h4">Role paths</h2><p>Citizen app is public. Staff control room supports Admin, Dispatcher, and department responders with scoped queues.</p><a class="btn btn-outline-info" href="/Auth/Login">Staff Login</a></div></div></div>
</div>
}
