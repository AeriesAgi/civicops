@model IEnumerable<CivicOps.Controllers.ConnectorInfo>
@{
    ViewData["Title"] = "Connector Status";
}

<div class="container">
    <h1 style="color: #06b6d4; margin-bottom: 2rem;">🔌 Connector Readiness</h1>

    <div class="card" style="margin-bottom: 2rem;">
        <p style="color: #cbd5e1; line-height: 1.8;">
            CivicOps is built as an integration-ready platform. Each connector below shows its current status and what's needed to enable it in production.
            Demo mode allows full functionality without external dependencies.
        </p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        @foreach (var connector in Model)
        {
            var statusColor = connector.Mode switch
            {
                "Configured" => "#22c55e",
                "Demo" => "#fbbf24",
                "Placeholder" => "#94a3b8",
                _ => "#06b6d4"
            };

            var statusBg = connector.Mode switch
            {
                "Configured" => "rgba(34, 197, 94, 0.1)",
                "Demo" => "rgba(251, 191, 36, 0.1)",
                "Placeholder" => "rgba(148, 163, 184, 0.1)",
                _ => "rgba(6, 182, 212, 0.1)"
            };

            <div class="card" style="border-left: 4px solid @statusColor;">
                <div style="display: flex; justify-content: between; align-items: start; margin-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
                    <div style="flex: 1;">
                        <h3 style="color: #e0e7ff; margin-bottom: 0.5rem;">@connector.Name</h3>
                        <p style="color: #94a3b8; margin-bottom: 1rem;">@connector.Description</p>
                    </div>
                    <div style="display: inline-block; padding: 0.5rem 1rem; background: @statusBg; border: 1px solid @statusColor; border-radius: 0.5rem;">
                        <div style="font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">Status</div>
                        <div style="font-weight: 600; color: @statusColor; margin-top: 0.25rem;">@connector.Mode</div>
                    </div>
                </div>

                <div style="display: grid; gap: 0.75rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(148, 163, 184, 0.2);">
                    <div style="display: flex; justify-content: space-between; padding: 0.5rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.375rem;">
                        <span style="color: #94a3b8; font-size: 0.875rem;">Current Status:</span>
                        <span style="color: #e0e7ff; font-size: 0.875rem; font-weight: 600;">@connector.Status</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; padding: 0.5rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.375rem;">
                        <span style="color: #94a3b8; font-size: 0.875rem;">Environment Variables:</span>
                        <span style="color: #e0e7ff; font-size: 0.875rem; font-family: monospace;">@connector.EnvVars</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; padding: 0.5rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.375rem;">
                        <span style="color: #94a3b8; font-size: 0.875rem;">Documentation:</span>
                        <span style="color: #06b6d4; font-size: 0.875rem;">@connector.Documentation</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card" style="margin-top: 2rem; background: rgba(6, 182, 212, 0.1); border-color: rgba(6, 182, 212, 0.3);">
        <h3 style="color: #06b6d4; margin-bottom: 1rem;">Production Deployment Notes</h3>
        <ul style="color: #cbd5e1; line-height: 1.8;">
            <li>Set environment variables in your hosting environment (Azure, AWS, etc.)</li>
            <li>Never commit API keys or secrets to the repository</li>
            <li>Use .env files locally (already in .gitignore)</li>
            <li>Test each connector individually before full deployment</li>
            <li>Monitor connector health and fallback behavior</li>
            <li>Review connector documentation in /docs folder</li>
        </ul>
    </div>
</div>
