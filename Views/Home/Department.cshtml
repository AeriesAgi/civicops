@model List<CivicOps.Models.Incident>
@{
    ViewData["Title"] = ViewBag.DepartmentName + " Queue";
}

<div class="container">
    <h1 style="color: #06b6d4; margin-bottom: 2rem;">@ViewBag.DepartmentName - Incident Queue</h1>

    @if (Model.Any())
    {
        <div class="card" style="margin-bottom: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <h3 style="color: #cbd5e1; margin: 0;">@Model.Count Incidents</h3>
                </div>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    <span style="padding: 0.5rem 1rem; background: rgba(251, 191, 36, 0.2); border-radius: 0.5rem; color: #fbbf24;">
                        New: @Model.Count(i => i.Status == CivicOps.Models.IncidentStatus.New)
                    </span>
                    <span style="padding: 0.5rem 1rem; background: rgba(59, 130, 246, 0.2); border-radius: 0.5rem; color: #3b82f6;">
                        In Progress: @Model.Count(i => i.Status == CivicOps.Models.IncidentStatus.InProgress)
                    </span>
                    <span style="padding: 0.5rem 1rem; background: rgba(239, 68, 68, 0.2); border-radius: 0.5rem; color: #ef4444;">
                        Escalated: @Model.Count(i => i.Status == CivicOps.Models.IncidentStatus.Escalated)
                    </span>
                </div>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
            @foreach (var incident in Model)
            {
                var priorityColor = incident.Priority switch
                {
                    CivicOps.Models.IncidentPriority.Urgent => "#ef4444",
                    CivicOps.Models.IncidentPriority.High => "#f97316",
                    CivicOps.Models.IncidentPriority.Medium => "#fbbf24",
                    _ => "#06b6d4"
                };

                <a href="/Home/Incident?id=@incident.Id" style="text-decoration: none;">
                    <div class="card" style="border-left: 4px solid @priorityColor;">
                        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
                            <div style="flex: 1;">
                                <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 0.5rem;">
                                    <span style="font-family: monospace; color: #06b6d4; font-weight: 600; font-size: 1.125rem;">
                                        @incident.ReferenceNumber
                                    </span>
                                    <span style="padding: 0.25rem 0.75rem; background: rgba(6, 182, 212, 0.2); border-radius: 1rem; color: #06b6d4; font-size: 0.875rem;">
                                        @incident.Status
                                    </span>
                                </div>
                                <h3 style="color: #e0e7ff; margin-bottom: 0.5rem;">@incident.Category</h3>
                                <p style="color: #cbd5e1; margin-bottom: 0.75rem;">@incident.AISummary</p>
                                <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.875rem; color: #94a3b8;">
                                    <span>📍 @incident.Suburb, @incident.Ward</span>
                                    <span>📅 @incident.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                    <span>🔄 @incident.SourceChannel</span>
                                </div>
                            </div>
                            <div style="text-align: right;">
                                <div style="padding: 0.5rem 1rem; background: rgba(239, 68, 68, 0.1); border: 1px solid @priorityColor; border-radius: 0.5rem;">
                                    <div style="font-size: 0.75rem; color: #94a3b8; text-transform: uppercase;">Priority</div>
                                    <div style="font-weight: 600; color: @priorityColor; margin-top: 0.25rem;">@incident.Priority</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="card" style="text-align: center; padding: 3rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">✅</div>
            <h3 style="color: #cbd5e1; margin-bottom: 0.5rem;">No Incidents</h3>
            <p style="color: #94a3b8;">This department has no pending incidents.</p>
        </div>
    }

    <div style="margin-top: 2rem;">
        <a href="/Home/Dashboard" class="btn btn-secondary">
            Back to Dashboard
        </a>
    </div>
</div>
