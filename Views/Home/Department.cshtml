@model List<CivicOps.Models.Incident>
@{
    ViewData["Title"] = ViewBag.DepartmentName + " Queue";
    string StatusLabel(CivicOps.Models.IncidentStatus s) => s switch { CivicOps.Models.IncidentStatus.InProgress => "In Progress", CivicOps.Models.IncidentStatus.WaitingForCitizen => "Waiting for Citizen", CivicOps.Models.IncidentStatus.AlertRecommended => "Alert Recommended", _ => s.ToString() };
    string PriorityLabel(CivicOps.Models.IncidentPriority p) => p == CivicOps.Models.IncidentPriority.Urgent ? "Critical" : p.ToString();
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Department queue</span><h1 class="display-5">@ViewBag.DepartmentName</h1><p class="lead">Role-scoped operational queue with direct action links, affected counts, public update state and audit visibility.</p>@if (ViewBag.QueueScope != null) { <div class="alert alert-info">@ViewBag.QueueScope</div> }</section>
  <div class="grid-auto mb-4"><div class="ops-card"><div class="metric">@Model.Count</div><p>Total queue</p></div><div class="ops-card"><div class="metric text-info">@Model.Count(i => i.Status == CivicOps.Models.IncidentStatus.New || i.Status == CivicOps.Models.IncidentStatus.Triaged)</div><p>Needs acknowledgement</p></div><div class="ops-card"><div class="metric text-warning">@Model.Count(i => i.Status == CivicOps.Models.IncidentStatus.InProgress)</div><p>In progress</p></div><div class="ops-card"><div class="metric text-danger">@Model.Count(i => i.Priority == CivicOps.Models.IncidentPriority.Critical || i.Priority == CivicOps.Models.IncidentPriority.Urgent || i.Status == CivicOps.Models.IncidentStatus.Escalated)</div><p>Critical/escalated</p></div></div>
  <div class="ops-card"><h2 class="h4">Incident queue</h2><div class="table-responsive"><table class="table"><thead><tr><th>Reference</th><th>Area</th><th>Issue</th><th>Status</th><th>Priority</th><th>Confirmations</th><th>Action</th></tr></thead><tbody>@foreach (var incident in Model) { <tr><td><a href="/Home/Incident?id=@incident.Id">@incident.ReferenceNumber</a></td><td>@incident.NormalizedArea<br/><small>@incident.Ward</small></td><td>@incident.Category<br/><small>@incident.AISummary</small></td><td><span class="badge bg-info">@StatusLabel(incident.Status)</span></td><td><span class="badge bg-warning">@PriorityLabel(incident.Priority)</span></td><td>@incident.AffectedCount</td><td><a class="btn btn-sm btn-primary" href="/Home/Incident?id=@incident.Id">Open actions</a></td></tr> }</tbody></table></div>@if (!Model.Any()) { <div class="alert alert-success">No pending incidents in this department queue.</div> }</div>
</div>
