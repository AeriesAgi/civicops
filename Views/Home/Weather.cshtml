@model List<CivicOps.Models.WeatherData>
@{
    ViewData["Title"] = "Weather / Area Conditions";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Area context</span><h1 class="display-5">Weather / area conditions</h1><p class="lead">Sandbox weather-risk signals help illustrate how CivicOps can add context to civic response. This page does not claim an official weather feed.</p></section>
  <div class="grid-auto">@foreach (var w in Model) { <div class="ops-card"><span class="badge @(w.RiskLevel == "High" ? "bg-danger" : w.RiskLevel == "Medium" ? "bg-warning" : "bg-success")">@w.RiskLevel risk</span><h2 class="h5 mt-3">@w.AreaName</h2><p>@w.WeatherCondition</p><p><strong>Temp:</strong> @w.Temperature°C · <strong>Rain probability:</strong> @w.PrecipitationProbability% · <strong>Wind:</strong> @w.WindSpeed km/h</p><p>@w.RiskDescription</p><p class="small text-muted-strong">Updated @w.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC</p></div> }</div>
</div>
