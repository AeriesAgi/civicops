@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Incident Details";
}

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 style="color: #06b6d4; margin-bottom: 0.5rem;">Incident Details</h1>
            <div style="font-size: 1.5rem; font-family: monospace; color: #cbd5e1;">@Model.ReferenceNumber</div>
        </div>
        <div style="display: inline-block; padding: 0.75rem 1.5rem; background: rgba(6, 182, 212, 0.2); border-radius: 0.5rem; border: 1px solid rgba(6, 182, 212, 0.3);">
            <div style="font-size: 0.875rem; color: #94a3b8;">Current Status</div>
            <div style="font-size: 1.5rem; font-weight: bold; color: #06b6d4; margin-top: 0.25rem;">@Model.Status</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        <div class="card">
            <h2 class="card-title">Incident Information</h2>
            <div style="display: grid; gap: 1rem;">
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Category</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.Category</div>
                </div>
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Department</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.AssignedDepartment.GetDisplayName()</div>
                </div>
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Priority</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.Priority</div>
                </div>
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Source Channel</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.SourceChannel</div>
                </div>
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Classification Method</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.ClassificationMethod</div>
                </div>
            </div>
        </div>

        <div class="card">
            <h2 class="card-title">Location & Contact</h2>
            <div style="display: grid; gap: 1rem;">
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Suburb</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.Suburb</div>
                </div>
                <div>
                    <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Ward</div>
                    <div style="color: #e0e7ff; font-weight: 600;">@Model.Ward</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.LocationNotes))
                {
                    <div>
                        <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Location Notes</div>
                        <div style="color: #e0e7ff;">@Model.LocationNotes</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.ContactName))
                {
                    <div>
                        <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.25rem;">Contact</div>
                        <div style="color: #e0e7ff;">@Model.ContactName</div>
                        @if (!string.IsNullOrEmpty(Model.ContactPhone))
                        {
                            <div style="color: #94a3b8; font-size: 0.875rem;">@Model.ContactPhone</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card" style="margin-top: 1.5rem;">
        <h2 class="card-title">Description</h2>
        <p style="color: #e0e7ff; line-height: 1.6; white-space: pre-wrap;">@Model.Description</p>
        @if (!string.IsNullOrEmpty(Model.AISummary) && Model.AISummary != Model.Description)
        {
            <div style="margin-top: 1rem; padding: 1rem; background: rgba(6, 182, 212, 0.1); border-left: 4px solid #06b6d4; border-radius: 0.5rem;">
                <div style="color: #94a3b8; font-size: 0.875rem; margin-bottom: 0.5rem;">AI Summary</div>
                <p style="color: #e0e7ff; margin: 0;">@Model.AISummary</p>
            </div>
        }
    </div>

    <div class="card" style="margin-top: 1.5rem;">
        <h2 class="card-title">Update Status</h2>
        <form method="post" asp-action="UpdateStatus" asp-route-id="@Model.Id">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label" for="status">New Status</label>
                    <select class="form-control" id="status" name="status" required>
                        <option value="New" selected="@(Model.Status == CivicOps.Models.IncidentStatus.New)">New</option>
                        <option value="Triaged" selected="@(Model.Status == CivicOps.Models.IncidentStatus.Triaged)">Triaged</option>
                        <option value="Assigned" selected="@(Model.Status == CivicOps.Models.IncidentStatus.Assigned)">Assigned</option>
                        <option value="InProgress" selected="@(Model.Status == CivicOps.Models.IncidentStatus.InProgress)">In Progress</option>
                        <option value="Escalated" selected="@(Model.Status == CivicOps.Models.IncidentStatus.Escalated)">Escalated</option>
                        <option value="Resolved" selected="@(Model.Status == CivicOps.Models.IncidentStatus.Resolved)">Resolved</option>
                        <option value="Closed" selected="@(Model.Status == CivicOps.Models.IncidentStatus.Closed)">Closed</option>
                    </select>
                </div>
                <div style="display: flex; align-items: end;">
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Update Status</button>
                </div>
            </div>
            <div class="form-group" style="margin-bottom: 0;">
                <label class="form-label" for="publicNote">Public Update (Optional)</label>
                <textarea class="form-control" id="publicNote" name="publicNote" rows="2" placeholder="Add a public update that residents can see"></textarea>
            </div>
        </form>
    </div>

    @if (Model.PublicUpdates.Any())
    {
        <div class="card" style="margin-top: 1.5rem;">
            <h2 class="card-title">Public Updates</h2>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                @foreach (var update in Model.PublicUpdates.AsEnumerable().Reverse())
                {
                    <div style="padding: 1rem; background: rgba(6, 182, 212, 0.1); border-left: 4px solid #06b6d4; border-radius: 0.5rem;">
                        <p style="color: #e0e7ff; margin: 0;">@update</p>
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.InternalNotes.Any())
    {
        <div class="card" style="margin-top: 1.5rem;">
            <h2 class="card-title">Internal Notes</h2>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                @foreach (var note in Model.InternalNotes.OrderByDescending(n => n.Timestamp))
                {
                    <div style="padding: 1rem; background: rgba(15, 23, 42, 0.6); border-radius: 0.5rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.875rem;">
                            <span style="color: #06b6d4; font-weight: 600;">@note.Author</span>
                            <span style="color: #94a3b8;">@note.Timestamp.ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                        <p style="color: #e0e7ff; margin: 0;">@note.Content</p>
                    </div>
                }
            </div>
        </div>
    }

    <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/Home/Department?dept=@Model.AssignedDepartment" class="btn btn-secondary">
            Back to Department Queue
        </a>
        <a href="/Home/Dashboard" class="btn btn-secondary">
            Dashboard
        </a>
    </div>
</div>
