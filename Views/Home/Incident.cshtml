@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Incident Detail";
    string StatusLabel(CivicOps.Models.IncidentStatus s) => s switch { CivicOps.Models.IncidentStatus.InProgress => "In Progress", CivicOps.Models.IncidentStatus.WaitingForCitizen => "Waiting for Citizen", CivicOps.Models.IncidentStatus.AlertRecommended => "Alert Recommended", _ => s.ToString() };
    string PriorityLabel(CivicOps.Models.IncidentPriority p) => p == CivicOps.Models.IncidentPriority.Urgent ? "Critical" : p.ToString();
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Municipal incident command</span><h1 class="display-5">@Model.ReferenceNumber</h1><p class="lead">@Model.Category in @Model.NormalizedArea · @Model.AssignedDepartment.GetDisplayName()</p><div class="d-flex flex-wrap gap-2"><span class="badge bg-info">@StatusLabel(Model.Status)</span><span class="badge bg-warning">@PriorityLabel(Model.Priority)</span><span class="badge bg-success">@Model.AffectedCount affected confirmations</span><span class="badge bg-secondary">@Model.ClassificationMethod</span></div></section>
  <div class="row g-4">
    <div class="col-lg-7">
      <div class="ops-card mb-4"><h2 class="h4">Incident information</h2><dl class="row"><dt class="col-sm-4">Source</dt><dd class="col-sm-8">@Model.SourceChannel</dd><dt class="col-sm-4">Original area</dt><dd class="col-sm-8">@Model.OriginalArea</dd><dt class="col-sm-4">Corrected area</dt><dd class="col-sm-8">@Model.NormalizedArea · @Model.Ward (@Model.WardConfidence)</dd><dt class="col-sm-4">Routing reason</dt><dd class="col-sm-8">@Model.RoutingReason</dd><dt class="col-sm-4">Alert recommendation</dt><dd class="col-sm-8">@Model.AlertRecommendation</dd><dt class="col-sm-4">Department brief</dt><dd class="col-sm-8">@Model.DepartmentBrief</dd><dt class="col-sm-4">Location notes</dt><dd class="col-sm-8">@Model.LocationNotes</dd></dl><h3 class="h5">Resident description</h3><p style="white-space:pre-wrap">@Model.Description</p></div>
      <div class="ops-card"><h2 class="h4">Operational workflow actions</h2><form method="post" asp-action="UpdateStatus" class="row g-3"><input type="hidden" name="id" value="@Model.Id" /><div class="col-md-6"><label class="form-label">Action</label><select name="actionType" class="form-select"><option value="acknowledge">Acknowledge report</option><option value="in-progress">Mark in progress</option><option value="request-info">Request more information</option><option value="escalate">Escalate</option><option value="recommend-alert">Recommend area alert</option><option value="resolve">Resolve</option><option value="close">Close</option><option value="generate-brief">Generate AI department brief</option><option value="generate-citizen-response">Generate AI citizen response</option></select></div><div class="col-md-3"><label class="form-label">Status override</label><select name="status" class="form-select"><option value="@Model.Status">Keep current</option><option value="Acknowledged">Acknowledged</option><option value="InProgress">In Progress</option><option value="WaitingForCitizen">Waiting for Citizen</option><option value="Escalated">Escalated</option><option value="AlertRecommended">Alert Recommended</option><option value="Resolved">Resolved</option><option value="Closed">Closed</option></select></div><div class="col-md-3"><label class="form-label">Priority</label><select name="priority" class="form-select"><option value="@Model.Priority">@PriorityLabel(Model.Priority)</option><option>Low</option><option>Medium</option><option>High</option><option>Critical</option></select></div><div class="col-12"><label class="form-label">Internal note</label><textarea name="internalNote" class="form-control" rows="2" placeholder="Crew assignment, operational decision, or audit note"></textarea></div><div class="col-12"><label class="form-label">Public update</label><textarea name="publicNote" class="form-control" rows="2" placeholder="Resident-facing status update"></textarea></div><div class="col-12 d-grid"><button class="btn btn-primary" type="submit">Apply workflow action</button></div></form></div>
    </div>
    <div class="col-lg-5"><div class="ops-card mb-4"><h2 class="h4">Public updates</h2><ol class="timeline-list">@foreach (var u in Model.PublicUpdates.OrderByDescending(u => u.Timestamp)) { <li><strong>@u.Timestamp.ToString("MMM dd HH:mm")</strong> — @u.Content</li> }</ol></div><div class="ops-card mb-4"><h2 class="h4">Status timeline</h2><ol class="timeline-list">@foreach (var h in Model.StatusHistory.OrderByDescending(h => h.Timestamp)) { <li><strong>@h.Timestamp.ToString("MMM dd HH:mm")</strong> — @StatusLabel(h.FromStatus) → @StatusLabel(h.ToStatus) by @h.ChangedBy<br/><small>@h.Reason</small></li> }</ol>@if (!Model.StatusHistory.Any()) { <p class="small text-muted-strong">No manual workflow actions yet.</p> }</div><div class="ops-card"><h2 class="h4">Internal audit/action log</h2><ol class="timeline-list">@foreach (var n in Model.InternalNotes.OrderByDescending(n => n.Timestamp)) { <li><strong>@n.Timestamp.ToString("MMM dd HH:mm")</strong> — @n.Author: @n.Content</li> }</ol></div></div>
  </div>
</div>
