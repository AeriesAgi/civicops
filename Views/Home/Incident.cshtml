@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Incident Detail";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Staff incident detail</span><h1 class="display-5">@Model.ReferenceNumber</h1><p class="lead"><span class="badge bg-info">@Model.Status</span> <span class="badge bg-warning">@Model.Priority</span> <span class="badge bg-info">@Model.AssignedDepartment.GetDisplayName()</span></p></section>
  <div class="row g-4"><div class="col-lg-6"><div class="ops-card"><h2 class="h4">Incident information</h2><dl><dt>Category</dt><dd>@Model.Category</dd><dt>Source</dt><dd>@Model.SourceChannel</dd><dt>AI source</dt><dd>@Model.ClassificationMethod</dd><dt>Original area</dt><dd>@Model.OriginalArea</dd><dt>Normalized area</dt><dd>@Model.NormalizedArea · @Model.Ward (@Model.WardConfidence)</dd><dt>Enrichment source</dt><dd>@Model.EnrichmentSource</dd><dt>Routing reason</dt><dd>@Model.RoutingReason</dd><dt>Department brief</dt><dd>@Model.DepartmentBrief</dd><dt>Location notes</dt><dd>@Model.LocationNotes</dd></dl><h3 class="h5">Description</h3><p style="white-space:pre-wrap">@Model.Description</p></div></div><div class="col-lg-6"><div class="ops-card"><h2 class="h4">Public updates</h2><ol class="timeline-list">@foreach (var u in Model.PublicUpdates.OrderByDescending(u => u.Timestamp)) { <li><strong>@u.Timestamp.ToString("MMM dd HH:mm")</strong> — @u.Content</li> }</ol></div><div class="ops-card mt-4"><h2 class="h4">Audit notes</h2><ol class="timeline-list">@foreach (var n in Model.InternalNotes.OrderByDescending(n => n.Timestamp)) { <li><strong>@n.Timestamp.ToString("MMM dd HH:mm")</strong> — @n.Content</li> }</ol></div></div></div>
</div>
