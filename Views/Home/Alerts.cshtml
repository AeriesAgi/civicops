@model List<CivicOps.Models.Alert>
@{
    ViewData["Title"] = "Area Alerts";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Public notices</span><h1 class="display-5">Area alerts</h1><p class="lead">Active synthetic civic notices by area, ward, severity and affected department. Public alerting remains human-reviewed.</p></section>
  <form method="get" asp-action="Alerts" class="ops-card mb-4"><div class="row g-3 align-items-end"><div class="col-md-5"><label class="form-label">Suburb</label><input class="form-control" name="suburb" value="@ViewBag.Suburb" placeholder="Chatsworth" /></div><div class="col-md-5"><label class="form-label">Ward</label><input class="form-control" name="ward" value="@ViewBag.Ward" placeholder="Ward 68" /></div><div class="col-md-2"><button class="btn btn-primary w-100">Filter</button></div></div></form>
  <div class="grid-auto">@foreach (var alert in Model) { <div class="ops-card"><span class="badge @(alert.Severity == CivicOps.Models.AlertSeverity.Critical ? "bg-danger" : alert.Severity == CivicOps.Models.AlertSeverity.Warning ? "bg-warning" : "bg-info")">@alert.Severity</span><h2 class="h5 mt-3">@alert.Title</h2><p>@alert.Description</p><p><strong>Area:</strong> @alert.Suburb · @alert.Ward</p><p><strong>Department:</strong> @alert.AffectedDepartment.GetDisplayName()</p><p class="small text-muted-strong">Created @alert.CreatedAt.ToString("MMM dd HH:mm") UTC</p></div> }</div>
  @if (!Model.Any()) { <div class="alert alert-info">No active alerts found for this filter.</div> }
</div>
