@model CivicOps.Models.Incident
@{
    ViewData["Title"] = "Report Confirmation";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Reference created</span><h1 class="display-5">Thank you — @Model.ReferenceNumber</h1><p class="lead">Your report has been validated, classified and routed for human review.</p><div class="d-flex gap-2 flex-wrap"><a class="btn btn-primary" href="/Home/Lookup">Track status</a><a class="btn btn-outline-info" href="/Home/Report">Submit another report</a><a class="btn btn-outline-light" href="/Home/Mobile">Open mobile hub</a></div></section>
  <div class="row g-4"><div class="col-lg-6"><div class="ops-card"><h2 class="h4">Routing</h2><dl><dt>Department</dt><dd>@Model.AssignedDepartment.GetDisplayName()</dd><dt>Category</dt><dd>@Model.Category</dd><dt>Priority</dt><dd>@Model.Priority</dd><dt>AI source</dt><dd>@Model.ClassificationMethod</dd></dl></div></div><div class="col-lg-6"><div class="ops-card"><h2 class="h4">Citizen response</h2><p>@(Model.PublicUpdates.LastOrDefault()?.Content ?? "Your report has been received.")</p><p class="small text-muted-strong">CivicOps does not replace emergency services.</p></div></div></div>
</div>
