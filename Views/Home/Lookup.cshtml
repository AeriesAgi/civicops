@{
    ViewData["Title"] = "Track Reference";
}
<div class="container py-4 civic-page">
  <section class="hero-panel mb-4"><span class="eyebrow">Public status lookup</span><h1 class="display-5">Track a CivicOps reference</h1><p class="lead">Enter a public reference number to see status, routed department, timeline and latest update.</p></section>
  <form asp-action="Lookup" method="post" class="ops-card">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <label class="form-label" for="referenceNumber">Reference number</label>
    <input class="form-control form-control-lg mb-3" id="referenceNumber" name="referenceNumber" placeholder="CIV-2026-0001" />
    <div class="d-flex gap-2 flex-wrap"><button class="btn btn-primary btn-lg" type="submit">Lookup status</button><a class="btn btn-outline-info btn-lg" href="/Home/Report">Report issue</a></div>
  </form>
</div>
