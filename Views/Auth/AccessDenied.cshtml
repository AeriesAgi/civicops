@{
    ViewData["Title"] = "Access Denied - CivicOps";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-shield-exclamation text-warning" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h2 class="fw-bold mb-3">Access Denied</h2>
                    <p class="text-muted mb-4">
                        You do not have permission to access this resource.
                    </p>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-primary">
                            <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-house me-2"></i>Go to Home
                        </a>
                    </div>

                    <hr class="my-4">

                    <div class="text-muted small">
                        <p class="mb-1">If you believe you should have access to this resource:</p>
                        <ul class="list-unstyled">
                            <li>Contact your system administrator</li>
                            <li>Verify you are logged in with the correct account</li>
                            <li>Check your assigned role and permissions</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
